Dialogue: 0,0:00:02.94,0:00:05.16,Italics,Okkotsu,0,0,0,,Kaynaklar sınırlı
Dialogue: 0,0:00:05.16,0:00:09.09,Italics,Okkotsu,0,0,0,,o yüzden Koloni'den çıkıp girmeyi sağlayacak bir Kural şüphesiz ki elzem olacak.
Dialogue: 0,0:00:09.70,0:00:11.80,Italics,Okkotsu,0,0,0,,Lakin Dhruv gibi
Dialogue: 0,0:00:11.80,0:00:16.25,Italics,Okkotsu,0,0,0,,umarsızca insanlara saldıran Oyuncular'ın bariyerleri terk etmesine izin veremem.
Dialogue: 0,0:00:16.74,0:00:21.43,Italics,Okkotsu,0,0,0,,Diğer Koloniler'deki böylelerini elimine ettikten sonra bu Kural gelecek.
Dialogue: 0,0:00:21.43,0:00:23.68,Italics,Okkotsu,0,0,0,,O yüzden Koloniler arası iletişim de elzem.
Dialogue: 0,0:00:23.56,0:00:33.22,Onscreen2,Screen,0,0,0,,{\fs60}{\fad(1376,1200)\pos(1620,108)}1: Puan Transferi
Dialogue: 0,0:00:23.56,0:00:33.22,Onscreen2,Screen,0,0,0,,{\fs60}{\fad(1376,1200)\pos(1179,150)}2: İtlaf Oyunu'ndan\N Kaçış
Dialogue: 0,0:00:23.56,0:00:33.22,Onscreen2,Screen,0,0,0,,{\fs60}{\fad(1376,1200)\pos(729,150)}3: Koloniler'e\N Girip Çıkabilme
Dialogue: 0,0:00:23.56,0:00:33.22,Onscreen2,Screen,0,0,0,,{\fs60}{\fad(1376,1200)\pos(270,150)}4: Koloniler Arası\N İletişim
Dialogue: 0,0:00:24.37,0:00:26.67,Italics,Okkotsu,0,0,0,,Fushiguro-kun'un önerdiği iki Kural daha var:
Dialogue: 0,0:00:26.67,0:00:29.30,Italics,Okkotsu,0,0,0,,Koloniler arası iletişim ve giriş çıkış izni.
Dialogue: 0,0:00:29.30,0:00:33.05,Italics,Okkotsu,0,0,0,,Bu durumu kontrol altına alabilmek için\N en az dört kural şart yani.
Dialogue: 0,0:00:33.62,0:00:35.59,Italics,Okkotsu,0,0,0,,Shibuya herkesi yordu.
Dialogue: 0,0:00:35.59,0:00:37.82,Italics,Okkotsu,0,0,0,,Sınırlarına dayandılar hem bedenen hem de ruhen.
Dialogue: 0,0:00:39.39,0:00:40.75,Italics,Okkotsu,0,0,0,,Sensei...
Dialogue: 0,0:00:41.56,0:00:44.93,Italics,Okkotsu,0,0,0,,Sensei'ye can dostunu tekrar öldürtmeyeceğim.
Dialogue: 0,0:00:45.55,0:00:47.54,Italics,Okkotsu,0,0,0,,Kenjaku'yu geberteceğim.
Dialogue: 0,0:00:47.54,0:00:49.90,Italics,Okkotsu,0,0,0,,400 puanı bir başıma elde edeceğim.
Dialogue: 0,0:00:49.90,0:00:52.90,Show_Title,Screen,0,0,0,,{\c&HE1008E&\3c&H000000&}JUJUTSU KAISEN
Dialogue: 0,0:00:56.67,0:00:59.01,Main,Okkotsu,0,0,0,,Gelebilirsiniz artık.
Dialogue: 0,0:00:59.01,0:01:02.61,Main,Okkotsu,0,0,0,,Kuzey'e, bariyerin ucuna gidiyoruz.
Dialogue: 0,0:01:02.61,0:01:04.43,Main,Daughter,0,0,0,,Taşı beni.
Dialogue: 0,0:01:04.43,0:01:05.49,Main,Mother,0,0,0,,Biraz daha dayan olur mu?
Dialogue: 0,0:01:06.34,0:01:08.30,Main,Okkotsu,0,0,0,,Mola verelim.
Dialogue: 0,0:01:08.30,0:01:12.68,Main,Okkotsu,0,0,0,,Demin galip geldiğim güçlü sahir,\N bu stadyumu kendi alanı bellemişti.
Dialogue: 0,0:01:12.68,0:01:16.25,Main,Okkotsu,0,0,0,,O yüzden bi' süre sessiz olur buralar.
Dialogue: 0,0:01:15.25,0:01:16.52,Main - Top,Oldman,0,0,0,,O ses neydi?
Dialogue: 0,0:01:20.91,0:01:23.26,Main,Okkotsu,0,0,0,,Stadyuma koşun.
Dialogue: 0,0:01:25.62,0:01:26.52,Main,Okkotsu,0,0,0,,Derhâl.
Dialogue: 0,0:01:33.91,0:01:35.07,Main,Man,0,0,0,,Ya... Yardım edin!
Dialogue: 0,0:01:40.55,0:01:43.04,Italics,Okkotsu,0,0,0,,Bu hamamböcekleri gerçek mi ki?
Dialogue: 0,0:01:44.93,0:01:45.54,Main,Okkotsu,0,0,0,,Siktir!
Dialogue: 0,0:01:52.01,0:01:53.51,Main,Okkotsu,0,0,0,,Rika! Yık şunu!
Dialogue: 0,0:01:53.51,0:01:54.45,Main,Man,0,0,0,,Acele edin!
Dialogue: 0,0:01:55.54,0:01:57.04,Main,Rika,0,0,0,,Tamaaam!
Dialogue: 0,0:02:10.70,0:02:13.02,Main,Okkotsu,0,0,0,,Kogane, o şey Oyuncu mu?
Dialogue: 0,0:02:14.14,0:02:16.86,Main,Kogane,0,0,0,,Evet! Adı Kurourushi!
Dialogue: 0,0:02:17.94,0:02:20.39,Main,Okkotsu,0,0,0,,Oyuncu lanetli ruhlar da mı var?
Dialogue: 0,0:02:21.49,0:02:24.49,Ep_Title,Screen,0,0,0,,Bölüm 59\N{\fs90}Sendai Kolonisi
Dialogue: 0,0:02:27.71,0:02:29.71,Sign_Basic,Screen,0,0,0,,{\fs60}{\pos(960,915)\bord0\shad0\fnTimes New Roman\b1\1a&H22&}Yaşam İrini Kılıcı
Dialogue: 0,0:02:47.86,0:02:49.15,Italics,Okkotsu,0,0,0,,İzleniyorum.
Dialogue: 0,0:02:49.75,0:02:53.11,Italics,Okkotsu,0,0,0,,Yüksek puanı olan o iki Oyuncu tarafından kesin.
Dialogue: 0,0:02:53.11,0:02:55.53,Main,Kurourushi,0,0,0,,Neden bölüyorsun?
Dialogue: 0,0:02:55.53,0:02:57.31,Italics,Okkotsu,0,0,0,,Kurourushi bir lanetli ruh.
Dialogue: 0,0:02:57.68,0:03:00.77,Main,Kurourushi,0,0,0,,Neden bizi öldürüyorsun?
Dialogue: 0,0:03:00.77,0:03:02.28,Italics,Okkotsu,0,0,0,,Lanetli ruhsa
Dialogue: 0,0:03:02.28,0:03:07.20,Italics,Okkotsu,0,0,0,,ters lanetli tekniğimle vücudunun içine pozitif enerji doldurarak arındırabilirim.
Dialogue: 0,0:03:07.85,0:03:09.79,Main,Okkotsu,0,0,0,,Asıl sana sormalı.
Dialogue: 0,0:03:10.25,0:03:11.09,Italics,Okkotsu,0,0,0,,Gelgelelim...
Dialogue: 0,0:03:11.31,0:03:14.77,Main,Kurourushi,0,0,0,,Demirin tadını seviyorum ben!
Dialogue: 0,0:03:17.89,0:03:22.55,Italics,Okkotsu,0,0,0,,Diğer ikisinin ters lanetli teknik\N kullanabildiğimi öğrenmesini istemiyorum.
Dialogue: 0,0:03:22.55,0:03:25.29,Italics,Okkotsu,0,0,0,,Ve de Rika stadyumdaki herkesi koruyor.
Dialogue: 0,0:03:25.29,0:03:29.02,Italics,Okkotsu,0,0,0,,Kurourushi'yi ne Rika'yı ne de ters lanetli tekniği kullanarak arındırmak istiyorum.
Dialogue: 0,0:03:35.36,0:03:39.02,Main,Kurourushi,0,0,0,,Karanlık, karanlık, karanlık...
Dialogue: 0,0:04:51.78,0:04:54.34,Main,Kogane,0,0,0,,Hanenize beş puan eklendi.
Dialogue: 0,0:04:54.34,0:04:56.31,Main,Uro,0,0,0,,Kullanabiliyorsun demek...
Dialogue: 0,0:04:56.95,0:04:58.44,Main,Uro,0,0,0,,ters lanetli tekniği.
Dialogue: 0,0:05:06.30,0:05:08.04,Main,Okkotsu,0,0,0,,Bu da neydi şimdi?
Dialogue: 0,0:05:08.04,0:05:08.79,Main,Okkotsu,0,0,0,,Saldırıyor mu?
Dialogue: 0,0:05:19.11,0:05:20.76,Italics,Okkotsu,0,0,0,,Kolum normale döndü.
Dialogue: 0,0:05:20.76,0:05:22.12,Italics,Okkotsu,0,0,0,,Tertemizim.
Dialogue: 0,0:05:22.12,0:05:25.17,Italics,Okkotsu,0,0,0,,Tekniğiyle uzayı manipüle ediyor muhtemelen.
Dialogue: 0,0:05:25.17,0:05:28.41,Italics,Okkotsu,0,0,0,,Ama rakibine bahsi geçen uzayla zarar veremiyor.
Dialogue: 0,0:05:28.41,0:05:31.89,Italics,Okkotsu,0,0,0,,Mercek kaynaklı çarpıtma yapıyor sanki.
Dialogue: 0,0:05:32.19,0:05:36.52,Main,Uro,0,0,0,,Tekniğim 'gökyüzü'ne 'yüzey' muamelesi yapıyor.
Dialogue: 0,0:05:38.38,0:05:39.71,Main,Uro,0,0,0,,Tıpkı şöyle.
Dialogue: 0,0:05:40.34,0:05:42.11,Italics,Okkotsu,0,0,0,,Tekniğini ifşa ediyor!
Dialogue: 0,0:05:42.73,0:05:44.81,Italics,Uro,0,0,0,,Hadisene saldır artık.
Dialogue: 0,0:05:45.39,0:05:47.75,Main,Okkotsu,0,0,0,,Soracağım var...
Dialogue: 0,0:05:47.75,0:05:50.39,Main,Okkotsu,0,0,0,,Ölmekten yakınacak biri değilsindir di' mi?
Dialogue: 0,0:05:50.39,0:05:53.59,Main,Okkotsu,0,0,0,,Güçsüzlerin neden çaresizliğe kapıldığını anlıyorum
Dialogue: 0,0:05:53.59,0:05:57.43,Main,Okkotsu,0,0,0,,ama senin gibi güçlü biri elini sallasa elli puan alır.
Dialogue: 0,0:05:57.43,0:06:00.25,Main,Okkotsu,0,0,0,,Ne diye savaş peşindesin o zaman?
Dialogue: 0,0:06:00.58,0:06:01.87,Italics,Uro,0,0,0,,Bu herif...
Dialogue: 0,0:06:02.29,0:06:06.80,Main,Uro,0,0,0,,Ne yani, bu çağın sahirleri enkarnasyon \Nkonusunda bu kadar rahat mı?
Dialogue: 0,0:06:06.80,0:06:10.30,Main,Uro,0,0,0,,Cehennemden geldik buraya biz cehennemden!
Dialogue: 0,0:06:10.72,0:06:15.72,Main,Uro,0,0,0,,Pişmanlığı olmadan sefa sürmüş kimse gidip Kenjaku'nun teklifini kabul etmez, değil mi?
Dialogue: 0,0:06:13.29,0:06:15.72,Main,Uro,0,0,0,,
Dialogue: 0,0:06:16.16,0:06:17.86,Italics,Uro,0,0,0,,Damarıma basıyor.
Dialogue: 0,0:06:18.23,0:06:22.37,Main,Uro,0,0,0,,İtlaf Oyunu hayattaki ikinci şansımız için\N bir ilk adım sadece.
Dialogue: 0,0:06:22.77,0:06:25.98,Main,Uro,0,0,0,,Nitekim her şeyi kurgulayan kişi Kenjaku.
Dialogue: 0,0:06:25.98,0:06:29.55,Main,Uro,0,0,0,,Her an her şey yapabileceği ihtimaline karşı puan toplamak en mantıklısı.
Dialogue: 0,0:06:30.22,0:06:32.94,Main,Okkotsu,0,0,0,,Arkadaşın ya da sevgilin falan yok mu hiç?
Dialogue: 0,0:06:35.07,0:06:35.98,Main,Uro,0,0,0,,Ha?
Dialogue: 0,0:06:36.80,0:06:40.28,Main,Okkotsu,0,0,0,,Ben de son zamanlar pek sosyalleşemedim
Dialogue: 0,0:06:40.28,0:06:42.22,Main,Okkotsu,0,0,0,,ama yine de anlayamıyorum seni.
Dialogue: 0,0:06:42.22,0:06:44.65,Italics,Uro,0,0,0,,Evet işte, bu his...
Dialogue: 0,0:06:44.65,0:06:47.41,Italics,Uro,0,0,0,,Patladım patlayacağım şimdi.
Dialogue: 0,0:06:48.13,0:06:49.84,Main,Okkotsu,0,0,0,,Pişmanlıkların olsa dahi
Dialogue: 0,0:06:49.84,0:06:52.47,Main,Okkotsu,0,0,0,,yüzlerce, binlerce yıllarca sonra zamanını\N insanları öldürmeye harcıyorsun.
Dialogue: 0,0:06:52.84,0:06:55.96,Main,Okkotsu,0,0,0,,Niye yalnız kendin için çabalıyorsun?
Dialogue: 0,0:06:55.96,0:07:00.23,Main,Uro,0,0,0,,Sen... Fujiwaralar'dan mısın?
Dialogue: 0,0:07:00.72,0:07:04.27,Main,Uro,0,0,0,,Senin soyundan biri ne anlar ki?
Dialogue: 0,0:07:14.34,0:07:15.86,Main,Ishigori,0,0,0,,Granit Patlaması.
Dialogue: 0,0:07:25.59,0:07:27.04,Italics,Okkotsu,0,0,0,,İshigori mi?
Dialogue: 0,0:07:27.39,0:07:29.06,Italics,Uro,0,0,0,,Oradaki çatıda mı?
Dialogue: 0,0:07:29.06,0:07:31.05,Italics,Uro,0,0,0,, Çok yakındı.
Dialogue: 0,0:07:31.29,0:07:34.93,Italics,Okkotsu,0,0,0,,Rika stadyumdaki insanları koruyor da olsa
Dialogue: 0,0:07:34.93,0:07:38.53,Italics,Okkotsu,0,0,0,,öyle doğrudan büyük bir saldırı\N zayiata sebep olacaktır.
Dialogue: 0,0:07:38.53,0:07:39.81,Italics,Okkotsu,0,0,0,,Önce İshigori'yi...
Dialogue: 0,0:07:40.37,0:07:45.22,Italics,Uro,0,0,0,,Kurourushi ve Dhruv da aradan çıktığına göre\N İshigori'yi salmaya gerek kalmadı.
Dialogue: 0,0:07:45.76,0:07:47.47,Italics,Uro,0,0,0,,Okkotsu'yu da onu da...
Dialogue: 0,0:07:47.47,0:07:48.52,Italics,Okkotsu,0,1000,0,,...aradan çıkartacağım!
Dialogue: 0,0:07:47.47,0:07:48.52,Italics,Uro,1000,0,0,,...aradan çıkartacağım!
Dialogue: 0,0:07:50.33,0:07:52.49,Main,Ishigori,0,0,0,,Granit Patlaması!
Dialogue: 0,0:08:05.12,0:08:08.38,Main,Ishigori,0,0,0,,Bana bak, yüzümü kara çıkarma.
Dialogue: 0,0:08:10.38,0:08:11.53,Main,Ishigori,0,0,0,,Kayboldu.
Dialogue: 0,0:08:11.53,0:08:14.77,Main,Ishigori,0,0,0,,Doğru ya! Daha evvel delik açtığı yerdi orası!
Dialogue: 0,0:08:19.21,0:08:21.86,Main,Okkotsu,0,0,0,,Biraz daha dip dibe halledelim lütfen.
Dialogue: 0,0:08:21.86,0:08:25.94,Main,Ishigori,0,0,0,,Açlığımı yatıştırır mı bu kadarı, Okkotsu?
Dialogue: 0,0:08:26.15,0:08:28.94,Eyecatch_Title,Screen,0,0,0,,{\fad(1625,0)\3c&HB7C4C2&}JUJUTSU KAISEN
Dialogue: 0,0:08:30.16,0:08:33.11,Main,Ishigori,0,0,0,,Sofradakileri yemek için can atan bir çocuğa
Dialogue: 0,0:08:33.11,0:08:36.06,Main,Ishigori,0,0,0,, 'sakin ol yavaş yavaş ye' der misin?
Dialogue: 0,0:08:37.41,0:08:39.30,Main,Okkotsu,0,0,0,,Kim demez ki?
Dialogue: 0,0:08:40.09,0:08:43.15,Main,Ishigori,0,0,0,,Doğru dedin. Çoğu derdi.
Dialogue: 0,0:08:43.15,0:08:44.74,Main,Ishigori,0,0,0,,Örnek kötüydü.
Dialogue: 0,0:08:45.28,0:08:49.30,Main,Ishigori,0,0,0,,İlk hayatımda ölçülü yerdim.
Dialogue: 0,0:08:49.93,0:08:52.38,Main,Ishigori,0,0,0,,Sağlam rakiplerim oldu
Dialogue: 0,0:08:52.38,0:08:54.48,Main,Ishigori,0,0,0,,harika bir kadınla da tanıştım.
Dialogue: 0,0:08:54.96,0:08:59.23,Main,Ishigori,0,0,0,,Dürüst olayım bak, pişmanlığım var desem yalan olur.
Dialogue: 0,0:09:00.82,0:09:05.94,Main,Ishigori,0,0,0,,Ama bu ne idüğü belirsiz açlığım\N başa bela bak, Okkotsu.
Dialogue: 0,0:09:05.94,0:09:09.46,Main,Ishigori,0,0,0,,Herkes "Nedir bu doyumsuzluğun sebebi?"\N diyordu resmen bana.
Dialogue: 0,0:09:07.13,0:09:09.46,Main,Ishigori,0,0,0,,
Dialogue: 0,0:09:11.73,0:09:15.41,Main,Ishigori,0,0,0,,Bu sigaralar ağızda hoş bir tat bırakıyor.
Dialogue: 0,0:09:16.99,0:09:21.21,Main,Ishigori,0,0,0,,Hayatımda hiç tatlım olmadı.
Dialogue: 0,0:09:22.07,0:09:23.21,Italics,Okkotsu,0,0,0,,Geliyor!
Dialogue: 0,0:09:31.45,0:09:33.67,Italics,Ishigori,0,0,0,,Nereden geliyor bu doyumsuzluk?
Dialogue: 0,0:09:34.47,0:09:36.37,Italics,Ishigori,0,0,0,,Bence biliyorsun!
Dialogue: 0,0:09:43.75,0:09:46.73,Italics,Ishigori,0,0,0,,KARNIM AÇ DA ONDAN!
Dialogue: 0,0:10:01.22,0:10:03.50,Main,Ishigori,0,0,0,,Sakın ezildim gittim deme!
Dialogue: 0,0:10:04.75,0:10:05.88,Main,Ishigori,0,0,0,,Hoppala.
Dialogue: 0,0:10:19.83,0:10:21.06,Main,Ishigori,0,0,0,,Acıdı be.
Dialogue: 0,0:10:38.43,0:10:39.06,Main,Okkotsu,0,0,0,,Güzel.
Dialogue: 0,0:10:46.04,0:10:48.17,Main,Ishigori,0,0,0,,Shikigamini çağırmayacak mısın?
Dialogue: 0,0:10:49.69,0:10:51.09,Main,Okkotsu,0,0,0,,Çağıramam.
Dialogue: 0,0:10:51.69,0:10:53.67,Main,Okkotsu,0,0,0,,Sen böyle çıldırırken olmaz.
Dialogue: 0,0:10:53.89,0:10:55.85,Main,Ishigori,0,0,0,,Yazık oldu işte.
Dialogue: 0,0:10:58.74,0:11:00.97,Italics,Okkotsu,0,0,0,,Muhtemelen yollarımı kısıtlamaya çalışıyor...
Dialogue: 0,0:11:02.15,0:11:03.73,Italics,Okkotsu,0,0,0,,ama yarıp geçeceğim...
Dialogue: 0,0:11:04.94,0:11:06.19,Italics,Okkotsu,0,0,0,,doğrudan!
Dialogue: 0,0:11:07.35,0:11:08.68,Main,Ishigori,0,0,0,,Tatlı!
Dialogue: 0,0:11:08.68,0:11:10.36,Main,Ishigori,0,0,0,,İşte böyle Okkotsu!
Dialogue: 0,0:11:10.36,0:11:11.64,Main,Ishigori,0,0,0,,BÖYLE OLACAKSA...
Dialogue: 0,0:11:14.55,0:11:16.32,Italics,Okkotsu,0,0,0,,Lanetli enerjisi daha keskin!
Dialogue: 0,0:11:16.32,0:11:17.10,Italics,Okkotsu,0,0,0,,Kötü oldu bu!
Dialogue: 0,0:11:22.29,0:11:24.46,Main,Ishigori,0,0,0,,Tebrik ederim! Al hediyen!
Dialogue: 0,0:11:28.55,0:11:30.03,Main,Ishigori,0,0,0,,Hoppa.
Dialogue: 0,0:11:30.03,0:11:32.09,Main,Ishigori,0,0,0,,Fazla ısındım.
Dialogue: 0,0:11:40.73,0:11:42.48,Main,Ishigori,0,0,0,,Fena değilsin Okkotsu!
Dialogue: 0,0:11:42.97,0:11:45.24,Main,Ishigori,0,0,0,,Sen benim...\N{\alpha&HFF&}TATLIM MISIN?
Dialogue: 0,0:11:45.24,0:11:46.35,Main,Ishigori,0,0,0,,Sen benim...\NTATLIM MISIN?
Dialogue: 0,0:11:53.49,0:11:55.13,Main,Ishigori,0,0,0,,Sen...\N {\alpha&HFF&}HARİKASIN ULAN!
Dialogue: 0,0:11:55.13,0:11:56.87,Main,Ishigori,0,0,0,,Sen...\N HARİKASIN ULAN!
Dialogue: 0,0:12:01.49,0:12:03.36,Italics,Uro,0,0,0,,Saldırdığım şey rakip değil de...
Dialogue: 0,0:12:03.71,0:12:05.50,Italics,Uro,0,0,0,,göğün 'yüzeyi'.
Dialogue: 0,0:12:07.42,0:12:08.96,Main,Uro,0,0,0,,İnce Buz Kıran!
Dialogue: 0,0:12:12.19,0:12:15.04,Main,Ishigori,0,0,0,,ÇEKİL SEN BE, İLLET KARI!
Dialogue: 0,0:12:17.62,0:12:20.39,Main,Uro,0,0,0,,Kes be, sik kafalı!
Dialogue: 0,0:12:26.69,0:12:28.50,Main,Uro,0,0,0,,Sağlamsın bakıyorum.
Dialogue: 0,0:12:28.50,0:12:29.67,Main,Uro,0,0,0,,Güzel güzel.
Dialogue: 0,0:12:29.67,0:12:32.06,Main,Uro,0,0,0,,Sana işkence edecektim zaten.
Dialogue: 0,0:12:33.64,0:12:35.04,Main,Ishigori,0,0,0,,Neydi öyle.
Dialogue: 0,0:12:35.04,0:12:38.28,Main,Ishigori,0,0,0,,İlk defa kendi tekniğimi yiyorum.
Dialogue: 0,0:12:38.91,0:12:41.37,Italics,Ishigori,0,0,0,,Ters lanetli tekniği başa dert de
Dialogue: 0,0:12:41.37,0:12:43.66,Italics,Ishigori,0,0,0,,ama oldukça fazla lanetli enerji yiyor.
Dialogue: 0,0:12:45.93,0:12:49.86,Main,Ishigori,0,0,0,,Sen de sınırına dayanmak üzeresin artık Okkotsu.
Dialogue: 0,0:12:50.23,0:12:52.87,Main,Ishigori,0,0,0,,Pastanenin ne kadar lezzetli\N ya da lüks pastaları olsa da
Dialogue: 0,0:12:52.87,0:12:55.02,Main,Ishigori,0,0,0,,kapanış vakti boş kalan raflar
Dialogue: 0,0:12:55.02,0:12:56.72,Main,Ishigori,0,0,0,,her zaman nahoş bir manzara olacak.
Dialogue: 0,0:12:58.09,0:12:59.98,Main,Ishigori,0,0,0,,Sen de olamazmışsın yani.
Dialogue: 0,0:13:05.75,0:13:10.00,Italics,Okkotsu,0,0,0,,Herkesin içinde olduğu stadyumdan\N uzak durmak istemiştim...
Dialogue: 0,0:13:10.00,0:13:11.27,Italics,Okkotsu,0,0,0,,Başka çarem yok.
Dialogue: 0,0:13:16.34,0:13:18.18,Main,Okkotsu,0,0,0,,Gel bakalım, Rika.
Dialogue: 0,0:13:19.25,0:13:20.40,Main,Okkotsu,0,0,0,,Her zerrenle.
Dialogue: 0,0:13:23.51,0:13:26.02,Italics,Uro,0,0,0,,Shikigamisi tamamen mi zuhur etti?
Dialogue: 0,0:13:26.02,0:13:27.77,Italics,Ishigori,0,0,0,,Bu nasıl iş be?
Dialogue: 0,0:13:27.77,0:13:30.39,Italics,Ishigori,0,0,0,,Lanetli enerjisi yine fırlamaya başladı!
Dialogue: 0,0:13:30.89,0:13:33.92,Main,Rika,0,0,0,,Yuta hangisini istersin?
Dialogue: 0,0:13:33.92,0:13:35.48,Main,Okkotsu,0,0,0,,Sağ ol.
Dialogue: 0,0:13:35.48,0:13:36.70,Main,Okkotsu,0,0,0,,Şunu alırım.
Dialogue: 0,0:13:38.81,0:13:41.70,Narration,Narration,0,0,0,,"Rika", Orimoto Rika'nın göçüp gitmesinin ardından
Dialogue: 0,0:13:41.70,0:13:43.79,Narration,Narration,0,0,0,,Okkotsu'ya bıraktığı lanetli tekniklerinin
Dialogue: 0,0:13:43.79,0:13:46.56,Narration,Narration,0,0,0,,ve lanetli enerjinin harici deposudur.
Dialogue: 0,0:13:46.71,0:13:49.38,Narration,Narration,0,0,0,,'Rika' ile yüzük aracılığıyla bağlı olduğu vakit
Dialogue: 0,0:13:49.38,0:13:51.97,Narration,Narration,0,0,0,,sırayla şunları elde eder:\N lanetli tekniklerini...
Dialogue: 0,0:13:51.97,0:13:53.65,Narration,Narration,0,0,0,,'Rika'nın tam zuhur etmiş hâlini...
Dialogue: 0,0:13:53.65,0:13:56.98,Narration,Narration,0,0,0,,ve de 'Rika'dan sağlanan lanetli enerjiyi.
Dialogue: 0,0:13:58.07,0:14:02.12,Narration,Narration,0,0,0,,Bu durum hâli yalnızca beş dakika sürer.
Dialogue: 0,0:14:04.26,0:14:05.31,Main,Okkotsu,0,0,0,,Tamamdır.
Dialogue: 0,0:14:05.80,0:14:06.90,Main,Okkotsu,0,0,0,,Gidelim.
Dialogue: 0,0:14:08.01,0:14:09.22,Italics,Uro,0,0,0,,Yabana atma beni!
Dialogue: 0,0:14:13.91,0:14:15.25,Main,Okkotsu,0,0,0,,Kıpırdama.
Dialogue: 0,0:14:14.03,0:14:15.45,Sign_Basic,Screen,0,0,0,,{\an8\fs90\b1\c&HCECECE&\shad0}Kıpırdama
Dialogue: 0,0:14:15.83,0:14:17.11,Italics,Uro,0,0,0,,Yılan gözleri ve dişleri!
Dialogue: 0,0:14:17.60,0:14:18.70,Italics,Uro,0,0,0,,Kıpırdayamıyorum!
Dialogue: 0,0:14:23.91,0:14:25.43,Main,Ishigori,0,0,0,,Buraya bak.
Dialogue: 0,0:14:25.66,0:14:27.43,Main,Ishigori,0,0,0,,FECİ TATLISIN SEN Dİ' Mİ!
Dialogue: 0,0:14:29.77,0:14:30.81,Main,Okkotsu,0,0,0,,Rika!
Dialogue: 0,0:14:30.81,0:14:31.35,Main,Rika,0,0,0,,Tabii!
Dialogue: 0,0:14:31.35,0:14:32.31,Main,Ishigori,0,0,0,,YAKALA!
Dialogue: 0,0:14:33.80,0:14:34.68,Italics,Ishigori,0,0,0,,Sağlammış!
Dialogue: 0,0:14:40.28,0:14:41.77,Main,Ishigori,0,0,0,,Yakındı!
Dialogue: 0,0:14:42.89,0:14:45.35,Main,Uro,0,0,0,,Kazandın sanma ulan!
Dialogue: 0,0:15:14.69,0:15:17.34,Main,Rika,0,0,0,,SEN!
Dialogue: 0,0:15:17.34,0:15:19.39,Main,Rika,0,0,0,,İŞİN BİTTİ SENİN!
Dialogue: 0,0:15:29.82,0:15:31.04,Italics,Okkotsu,0,0,0,,Ne?
Dialogue: 0,0:15:31.37,0:15:32.98,Main,Ishigori,0,0,0,,Başlayalım!
Dialogue: 0,0:15:35.62,0:15:36.40,Main,Ishigori,0,0,0,,İşte böyle!
Dialogue: 0,0:15:37.27,0:15:39.12,Italics,Okkotsu,0,0,0,,Bununla bile tamamen engelleyemiyorum!
Dialogue: 0,0:15:42.39,0:15:43.55,Main,Ishigo,0,0,0,,Yapıyor muyuz?
Dialogue: 0,0:16:12.68,0:16:14.08,Main,Uro,0,0,0,,İnce Buz Kıran!
Dialogue: 0,0:16:23.57,0:16:24.42,Main,Uro,0,0,0,,Peh!
Dialogue: 0,0:16:24.79,0:16:27.79,Sign_Basic,Screen,0,0,0,,{\an1\fs42\fnTimes New Roman\b1}Güneş, Ay ve Yıldızlar Takımı, Fujiwara Klanı'nın\Nkişisel suikastçı takımıydı.\NKaranlıkta yaşadık ve özverili bir bağlılıkla hizmet ettik.\NKendi isimlerimize sahip olmamız bile yasaktı.
Dialogue: 0,0:16:28.88,0:16:31.88,Sign_Basic,Screen,0,0,0,,{\an1\fs42\fnTimes New Roman\b1}Yine de o adam bir keresinde bana bir isim bahşetmişti.\NKendi akrabasını katletme suçundan dolayı\Nbenim idam edilebilmem için.
Dialogue: 0,0:16:32.97,0:16:34.71,Main,Uro,0,0,0,,Fujiwara!
Dialogue: 0,0:16:35.47,0:16:37.37,Main,Ishigori,0,0,0,,Hâlâ ama hâlâ...\N {\alpha&HFF&}MİDEM KAZINIYOR BENİM!
Dialogue: 0,0:16:37.37,0:16:39.16,Main,Ishigori,0,0,0,,Hâlâ ama hâlâ...\N MİDEM KAZINIYOR BENİM!
Dialogue: 0,0:16:40.67,0:16:42.52,Main,Ishigori,0,0,0,,TAM GAZ YARDIRALIM MI!
Dialogue: 0,0:16:44.26,0:16:45.88,Main,Uro,0,0,0,,Hep siz Fujiwaralar'sınız!
Dialogue: 0,0:16:46.21,0:16:48.52,Main,Uro,0,0,0,,Hep yoluma çıkarsınız!
Dialogue: 0,0:16:48.52,0:16:50.65,Main,Uro,0,0,0,,O kadar mı korkutucuyum be!
Dialogue: 0,0:16:50.65,0:16:53.41,Main,Uro,0,0,0,,Kendi benliğimi kazanmamdan mı korkuyorsun?
Dialogue: 0,0:16:59.41,0:17:02.99,Narration,Narration,0,0,0,,Okkotsu, Dhruv Lakdawalla'yı yenmişti.
Dialogue: 0,0:17:03.49,0:17:07.67,Narration,Narration,0,0,0,,Onun tekniği, shikigamisinin yolunu\Nbir bölgeye dönüştürüp
Dialogue: 0,0:17:07.67,0:17:10.98,Narration,Narration,0,0,0,,temas ettiği her şeyi kesmesi.
Dialogue: 0,0:17:13.63,0:17:16.66,Italics,Uro,0,0,0,,Bu... Dhruv'un tekniği!
Dialogue: 0,0:17:17.12,0:17:20.26,Italics,Uro,0,0,0,,Yoksa diyorum... Okkotsu'nun tekniği...
Dialogue: 0,0:17:20.26,0:17:21.35,Italics,Uro,0,0,0,,Kopya mı?
Dialogue: 0,0:17:34.12,0:17:38.02,Main,Okkotsu,0,0,0,,Atalarımla ne alıp veremediğin var bilmiyorum
Dialogue: 0,0:17:38.02,0:17:42.42,Main,Okkotsu,0,0,0,,ama sırf kendin için yaşarsan\N eninde sonunda sınırına ulaşacaksın.
Dialogue: 0,0:17:42.79,0:17:43.67,Main,Uro,0,0,0,,Kes!
Dialogue: 0,0:17:43.67,0:17:46.01,Main,Uro,0,0,0,,"Başkalarının uğruna yaşa!"
Dialogue: 0,0:17:46.01,0:17:48.29,Main,Uro,0,0,0,,"Kendi benliğine sahip olmana gerek yok!"
Dialogue: 0,0:17:49.57,0:17:54.93,Main,Uro,0,0,0,,Hep hayatta bir yere gelenlerin\N edeceği laflar bunlar!
Dialogue: 0,0:18:10.47,0:18:12.14,Main,Ishigori,0,0,0,,Ciyaklamayı kes ulan!
Dialogue: 0,0:18:12.14,0:18:13.81,Main,Ishigori,0,0,0,,Şu anda...
Dialogue: 0,0:18:15.58,0:18:17.62,Main,Ishigori,0,0,0,,KELİMELER KİFAYETSİZ!
Dialogue: 0,0:18:22.75,0:18:24.50,Main,Uro,1200,0,0,,{\fs70}BÖLGESEL\NGENİŞLEME!
Dialogue: 0,0:18:22.75,0:18:24.50,Main,Okkotsu,0,0,0,,{\fs70}Bölgesel\NGenişleme.
Dialogue: 0,0:18:22.75,0:18:24.50,Main,Ishigori,0,1200,0,,{\fs70}BÖLGESEL\NGENİŞLEME!
Dialogue: 0,0:18:26.83,0:18:29.96,Main,Rika,0,0,0,,YUTA'YI GERİ VER!
Dialogue: 0,0:18:29.96,0:18:32.84,Main,Uro,0,0,0,,Daha sonrasında bariyeri delmeye de çalışsa...
Dialogue: 0,0:18:33.03,0:18:34.84,Main,Ishigori,0,0,0,,İşi uzatmaya niyetim yok!
Dialogue: 0,0:18:34.84,0:18:37.29,Main,Ishigori,0,0,0,,Şu işi tatlıya bağlayalım hadi!
Dialogue: 0,0:18:39.17,0:18:43.46,Narration,Narration,0,0,0,,Tam o anda\N modern çağın kara şeytanı...
Dialogue: 0,0:18:43.46,0:18:45.04,Main,Kurourushi,0,0,0,,BEN {\alpha&HFF&}DEMİRİN TADINI SEVİYORUM!
Dialogue: 0,0:18:45.04,0:18:45.87,Main,Kurourushi,0,0,0,,BEN DEMİRİN {\alpha&HFF&}TADINI SEVİYORUM!
Dialogue: 0,0:18:45.87,0:18:46.46,Main,Kurourushi,0,0,0,,BEN DEMİRİN TADINI {\alpha&HFF&}SEVİYORUM!
Dialogue: 0,0:18:46.46,0:18:47.34,Main,Kurourushi,0,0,0,,BEN DEMİRİN TADINI SEVİYORUM!
Dialogue: 0,0:18:47.34,0:18:49.39,Narration,Narration,0,0,0,,...bariyerlerin içine fırladı.
Dialogue: 0,0:18:52.39,0:18:57.78,Narration,Narration,0,0,0,,Kurourushi, uykuya dalmadan önce\Npartenogenezini tamamlamıştı.
Dialogue: 0,0:18:58.72,0:19:02.60,Narration,Narration,0,0,0,,Bu yüzden Kurourushi, bir lanetli ruh olarak\N hâlâ daha turp gibiydi.
Dialogue: 0,0:19:03.16,0:19:06.91,Narration,Narration,0,0,0,,Üç bölgenin karmaşık güçleri\Nhepsini kontrol altında tutuyordu.
Dialogue: 0,0:19:07.80,0:19:11.14,Narration,Narration,0,0,0,,Ama bu davetsiz misafir beklenmedikti.
Dialogue: 0,0:19:11.93,0:19:13.50,Narration,Narration,0,0,0,,Dolayısıyla bariyerler...
Dialogue: 0,0:19:16.16,0:19:18.00,Narration,Narration,0,0,0,,yok oldu.
Dialogue: 0,0:19:23.35,0:19:24.93,Main,Uro,0,0,0,,Kurourushi nasıl daha hayatta?
Dialogue: 0,0:19:30.27,0:19:31.42,Italics,Uro,0,0,0,,Sıçayım!
Dialogue: 0,0:19:31.42,0:19:34.01,Italics,Uro,0,0,0,,Bölgesel Genişlemeden hemen sonra\N tekniğimi kullanamıyorum!
Dialogue: 0,0:19:40.77,0:19:42.79,Main,Uro,0,0,0,,Ne hakla kolumu alırsın!
Dialogue: 0,0:19:42.79,0:19:44.34,Main,Uro,0,0,0,,FUJİWARA!
Dialogue: 0,0:19:44.34,0:19:46.72,Main,Ishigori,0,0,0,,Yeter bu kadar, Uro.
Dialogue: 0,0:19:47.40,0:19:50.29,Main,Ishigori,0,0,0,,Siz ikiniz bu masaya davetli değilsiniz.
Dialogue: 0,0:19:52.30,0:19:54.26,Main,Ishigori,0,0,0,,Granit Patlaması.
Dialogue: 0,0:19:57.35,0:20:01.18,Narration,Narration,0,0,0,,İshigori'nin tekniği Lanetli Enerji Tahliyesi.
Dialogue: 0,0:20:01.18,0:20:05.84,Narration,Narration,0,0,0,,Oldukça basit bir saldırı da olsa\N tekniği bitap düştükten sonra dahi
Dialogue: 0,0:20:05.84,0:20:08.56,Narration,Narration,0,0,0,,oldukça iyi bir performans gösteriyor.
Dialogue: 0,0:20:16.86,0:20:17.91,Main,Ishigori,0,0,0,,Şimdi...
Dialogue: 0,0:20:21.22,0:20:23.00,Main,Ishigori,0,0,0,,bi' sandalye çek kendine...
Dialogue: 0,0:20:24.76,0:20:25.94,Main,Ishigori,0,0,0,,Okkotsu.
Dialogue: 0,0:20:27.11,0:20:28.88,Main,Okkotsu,0,0,0,,Gidelim, Rika.
Dialogue: 0,0:20:33.90,0:20:36.61,Narration,Narration,0,0,0,,'Rika' yalnızca tamamen zuhur ettiği vakit
Dialogue: 0,0:20:36.61,0:20:40.76,Narration,Narration,0,0,0,,Okkotsu yüksek miktarda\N lanetli enerji tahliyesi yapabilir.
Dialogue: 0,0:20:40.76,0:20:44.92,Narration,Narration,0,0,0,,Gelgelelim, maksimum çıktısı\N ufak da olsa İshigori'ninkinden az.
Dialogue: 0,0:20:46.18,0:20:49.70,Narration,Narration,0,0,0,,Bu yüzden de İshigori\N maksimum çıktıya ulaşamadan evvel
Dialogue: 0,0:20:49.70,0:20:52.01,Narration,Narration,0,0,0,,lanetli enerjisini biriktirip fırlatma kararını...
Dialogue: 0,0:20:52.64,0:20:54.44,Narration,Narration,0,0,0,,vermişti ki...
Dialogue: 0,0:20:55.35,0:21:00.94,Sign_Basic,Screen,0,0,0,,{\fad(0,3425)\an8\fnTimes New Roman\b1\fs90\bord0\shad0}Hepsini dışarı vuralım!
Dialogue: 0,0:20:57.59,0:21:00.57,Narration,Narration,0,0,0,,Dört yüz yıl süregelen bir özlem.
Dialogue: 0,0:21:00.57,0:21:03.44,Narration,Narration,0,0,0,,Gözlerindeki o açlık dolu bakışlar...
Dialogue: 0,0:21:03.78,0:21:09.22,Narration,Narration,0,0,0,,dövüşmekte muhtemelen hiçbir zaman\Nbir anlam bulamayacak olmasına rağmen
Dialogue: 0,0:21:09.22,0:21:11.96,Narration,Narration,0,0,0,,Okkotsu Yuta'nın yüreğini cezbetti.
Dialogue: 0,0:21:12.92,0:21:14.95,Main,Okkotsu,0,0,0,,Sadece bu seferlik bak.
Dialogue: 0,0:21:33.64,0:21:37.40,Main,Ishigori,0,0,0,,Aşırı tatlı oldu bu bak Okkotsu!
Dialogue: 0,0:21:47.50,0:21:48.97,Main,Ishigori,0,0,0,,AYNEN ÖYLE!
Dialogue: 0,0:21:48.97,0:21:51.28,Main,Ishigori,0,0,0,,DEFALARCA YAPALIM ŞUNU!
Dialogue: 0,0:21:54.86,0:21:57.14,Italics,Ishigori,0,0,0,,O koca şey kendi başına ateş edebiliyor mu?
Dialogue: 0,0:21:57.70,0:21:58.75,Italics,Ishigori,0,0,0,,Ama...
Dialogue: 0,0:21:59.76,0:22:01.65,Italics,Ishigori,0,0,0,,güç bakımından zayıf!
Dialogue: 0,0:22:03.16,0:22:05.91,Italics,Ishigori,0,0,0,,Bölgesel Genişlemeden\N ve benle bir öğünden sonra...
Dialogue: 0,0:22:06.76,0:22:11.15,Italics,Ishigori,0,0,0,,sen bile o kadar toparlanamamışsındır.
Dialogue: 0,0:22:11.48,0:22:12.96,Main,Ishigori,0,0,0,,Bitiriyorum.
Dialogue: 0,0:22:13.38,0:22:15.75,Main,Ishigori,0,0,0,,Granit Patlaması!
Dialogue: 0,0:22:20.39,0:22:22.63,Italics,Narration,0,0,0,,Okkotsu'nun lanetli tekniği...
Dialogue: 0,0:22:23.53,0:22:25.75,Italics,Narration,0,0,0,,çoktan yenilenmişti.
Dialogue: 0,0:22:28.45,0:22:30.34,Italics,Ishigori,0,0,0,,Uro'nun tekniği mi?
Dialogue: 0,0:22:30.83,0:22:33.59,Italics,Ishigori,0,0,0,,Lanetli hitabet kullanıcısından\N ibaret olmadığını anlamıştım!
Dialogue: 0,0:22:33.59,0:22:38.40,Italics,Ishigori,0,0,0,,Şu büyük şey muhtemelen Okkotsu'nunkinden\N farklı bir tekniğe sahip sanmıştım
Dialogue: 0,0:22:38.40,0:22:39.68,Italics,Ishigori,0,0,0,,yanılmışım ama!
Dialogue: 0,0:22:39.68,0:22:42.03,Italics,Ishigori,0,0,0,,Okkotsu'nun tekniği Kopya!
Dialogue: 0,0:22:42.03,0:22:43.85,Italics,Ishigori,0,0,0,,Ama ağır koşulları vardır!
Dialogue: 0,0:22:43.85,0:22:45.80,Italics,Ishigori,0,0,0,,Ne zaman? Ne zaman koşulları karşıladı?
Dialogue: 0,0:22:45.80,0:22:47.05,Italics,Ishigori,0,0,0,,Ben bakmıyorken mi?
Dialogue: 0,0:22:47.43,0:22:49.43,Italics,Ishigori,0,0,0,,Sakın bana koşul yok falan deme!
Dialogue: 0,0:22:53.70,0:22:55.43,Italics,Ishigori,0,0,0,,O andı!
Dialogue: 0,0:22:55.98,0:22:57.23,Main,Okkotsu,0,0,0,,İnce Buz Kıran!
Dialogue: 0,0:23:08.45,0:23:09.56,Narration,Narration,0,0,0,,Beş dakika.
Dialogue: 0,0:23:10.01,0:23:13.11,Narration,Narration,0,0,0,,Okkotsu'nun 'Rika' ile olan bağlantısı kesildi.
Dialogue: 0,0:23:19.54,0:23:21.72,Main,Rika,0,0,0,,Yuta!
Dialogue: 0,0:23:24.90,0:23:26.59,Main,Ishigori,0,0,0,,Hiç haberim yoktu...
Dialogue: 0,0:23:30.33,0:23:33.47,Main,Ishigori,0,0,0,,HER ŞEYİ SIKTIKTAN SONRA\N DAHASININ OLDUĞUNDAN!
Dialogue: 0,0:23:36.32,0:23:40.09,Italics,Ishigori,0,0,0,,Demek ki bu... tatlı ha!
Dialogue: 0,0:24:02.09,0:24:03.61,Main,Okkotsu,0,0,0,,Bitiriyoruz artık.
Dialogue: 0,0:24:07.17,0:24:08.03,Italics,Ishigori,0,0,0,,Ne?
Dialogue: 0,0:24:08.80,0:24:10.38,Italics,Ishigori,0,0,0,,Neyin peşinde bu!
Dialogue: 0,0:24:27.21,0:24:29.82,Italics,Ishigori,0,0,0,,Benim miydi bu?
Dialogue: 0,0:24:32.64,0:24:34.04,Italics,Ishigori,0,0,0,,O vakit...
Dialogue: 0,0:24:34.04,0:24:37.86,Italics,Ishigori,0,0,0,,Uro'nun tekniğini kullanarak\N bana geri mi döndürdü?
Dialogue: 0,0:24:41.05,0:24:42.60,Main,Ishigori,0,0,0,,Teşekkürler.
Dialogue: 0,0:24:49.47,0:24:51.46,Main,Ishigori,0,0,0,,Tıka basa doydum.
Dialogue: 0,0:25:09.32,0:25:11.85,Main,Ishigori,0,0,0,,Çok yufka yüreklisin, Okkotsu.
Dialogue: 0,0:25:12.72,0:25:14.71,Main,Ishigori,0,0,0,,Övgü değildi bu bak.
Dialogue: 0,0:25:14.71,0:25:16.96,Main,Ishigori,0,0,0,,Seni öldürmek adına savaşan sahirin\N canını bağışlamanın...
Dialogue: 0,0:25:16.96,0:25:19.70,Main,Okkotsu,0,0,0,,Bir kazancı yok bana.
Dialogue: 0,0:25:19.70,0:25:21.08,Main,Okkotsu,0,0,0,,Uro-san da aynını söyledi.
Dialogue: 0,0:25:21.47,0:25:23.65,Main,Ishigori,0,0,0,,O karı hâlâ hayatta mı?
Dialogue: 0,0:25:25.21,0:25:29.45,Main,Ishigori,0,0,0,,Şey, patlamam Bölgesel Genişlemeden\N sonra zayıfladı herhalde.
Dialogue: 0,0:25:29.80,0:25:32.54,Main,Ishigori,0,0,0,,Sana bir şey vızıldıyordu sürekli.
Dialogue: 0,0:25:32.54,0:25:33.75,Main,Ishigori,0,0,0,,Aşık atışması mı yapıyordunuz?
Dialogue: 0,0:25:34.25,0:25:35.79,Main,Okkotsu,0,0,0,,Öyle bir şey.
Dialogue: 0,0:25:36.35,0:25:38.35,Main,Ishigori,0,0,0,,İğrenmişsin gibi durma.
Dialogue: 0,0:25:38.35,0:25:41.28,Main,Okkotsu,0,0,0,,O kadına söyleyebilecek hiçbir şeyim yok.
Dialogue: 0,0:25:42.23,0:25:44.84,Main,Okkotsu,0,0,0,,Ne desem de sonuç kavgaya bağlanır.
Dialogue: 0,0:25:45.42,0:25:47.62,Main,Okkotsu,0,0,0,,Kutsandım da ondan.
Dialogue: 0,0:25:48.79,0:25:50.48,Main,Ishigori,0,0,0,,Öyle miymiş?
Dialogue: 0,0:25:50.48,0:25:52.42,Main,Ishigori,0,0,0,,Pek kafam basmıyor ama.
Dialogue: 0,0:25:53.66,0:25:55.23,Main,Okkotsu,0,0,0,,Neyse artık...
Dialogue: 0,0:25:55.69,0:25:57.26,Main,Okkotsu,0,0,0,,puanlarını verir misin?
Dialogue: 0,0:26:00.27,0:26:02.12,Main,Ishigori,0,0,0,,Anladım şimdi.
Dialogue: 0,0:26:02.12,0:26:05.18,Main,Ishigori,0,0,0,,Mevzu bu olmasa bizi öldürürdün di' mi?
Dialogue: 0,0:26:06.96,0:26:09.10,Main,Okkotsu,0,0,0,,Emin değilim ki ya.
Dialogue: 0,0:26:11.72,0:26:14.58,Main,Okkotsu,0,0,0,,Arkadaşlarıma şükretmelisiniz o konuda.
Dialogue: 0,0:26:17.60,0:26:20.84,Sign_Basic,Screen,0,0,0,,{\an8\fnTimes New Roman\b1\fs60\pos(960,600)}İshigori Ryu ve Uro Takako'nun\Npuanlarının aktarılmasıyla
Dialogue: 0,0:26:21.10,0:26:23.64,Sign_Basic,Screen,0,0,0,,{\an8\pos(960,600)\fnTimes New Roman\b1\fs60}Okkotsu Yuta 190 puana ulaştı.
Dialogue: 0,0:26:26.03,0:26:29.11,Flashback,Uro,0,0,0,,Sınırına ulaşacak olan sensin.
Dialogue: 0,0:26:32.66,0:26:34.61,Flashback,Uro,0,0,0,,Gördüğümden diyorum.
Dialogue: 0,0:26:38.21,0:26:40.13,Flashback,Uro,0,0,0,,Sahir de olsalar lanetli ruh da olsalar...
Dialogue: 0,0:26:40.35,0:26:43.36,Flashback,Uro,0,0,0,,gücün sınırını aşanların...
Dialogue: 0,0:26:44.61,0:26:46.87,Flashback,Uro,0,0,0,,hepsinin ezici egoları vardır.
Dialogue: 0,0:26:47.21,0:26:48.87,Flashback,Uro,0,0,0,,Başka şeylerle ilgilenmezler.
Dialogue: 0,0:26:49.40,0:26:50.62,Flashback,Uro,0,0,0,,Felaketler onlar.
Dialogue: 0,0:27:00.49,0:27:07.46,MainTop,,0,0,0,,{\fad(0,650)\fs66\c&HF3F3F3&\bord3\3c&H000000&\alpha&H00&)}çevirmen: barış akın/sogukhava\Nsezon finalidir ifinim. seneye görüşeceğiz.
Dialogue: 0,0:27:07.06,0:27:09.27,ED5,,0,0,0,,{\fade(250,0)\blur6\bord0\3c&H150808&\c&H150808&\t(0,2200,\3c&H1C0B0B&\c&H1C0B0B&)}Kararan günlerde
Dialogue: 0,0:27:09.27,0:27:13.69,ED5,,0,0,0,,{\blur6\bord0\3c&H1C0B0B&\c&H1C0B0B&\t(0,4400,\3c&H230E0E&\c&H230E0E&)}Yersiz yurtsuz bir gölge tek başına sendeler, yönünü bilmez bir hâlde
Dialogue: 0,0:27:13.69,0:27:18.49,ED5,,0,0,0,,{\blur6\bord0\3c&H230E0E&\c&H230E0E&\t(0,4400,\3c&H2B1111&\c&H2B1111&)}Sanki af dilenir gibi, ne kadar da acınası
Dialogue: 0,0:27:18.49,0:27:23.49,ED5,,0,0,0,,{\blur6\bord0\3c&H2B1111&\c&H2B1111&}Ekilen tohumlar filizlenip başlar açmaya
Dialogue: 0,0:27:23.49,0:27:26.37,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}Sen ise giderek buz kesersin, dönersin soğuğa
Dialogue: 0,0:27:26.37,0:27:29.87,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}Uzattığım avuçlar, boşluğu kesip geçer
Dialogue: 0,0:27:29.87,0:27:32.88,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}Eskisi gibi olmaz mı, geriye dönmez mi her şey?
Dialogue: 0,0:27:32.88,0:27:36.21,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}Üzerime gelen dalgalar yutar beni, içine çeker
Dialogue: 0,0:27:36.21,0:27:39.38,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}Geleceği yıka yıka ilerlerim, durmam
Dialogue: 0,0:27:39.38,0:27:43.14,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}Söylesene, beklenen o son gelecek mi artık?
Dialogue: 0,0:27:44.18,0:27:46.85,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}Paramparça edilsem de
Dialogue: 0,0:27:46.85,0:27:48.39,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}Sökülüp atılsam da
Dialogue: 0,0:27:48.39,0:27:51.10,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}Sefilce savrulsam bile etrafa
Dialogue: 0,0:27:51.10,0:27:53.82,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}Korkmam asla
Dialogue: 0,0:27:53.82,0:27:57.03,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}Artık içim boş da ondan ola
Dialogue: 0,0:27:57.03,0:27:58.49,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}Bu yüzden de
Dialogue: 0,0:27:58.49,0:28:03.91,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}Son geldiğinde, o mutlak günde söndür artık bu ışığı, bitir bu çileyi de
Dialogue: 0,0:28:03.91,0:28:06.87,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}İstemem artık hiçbir şey
Dialogue: 0,0:28:06.87,0:28:09.79,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}Korkarım çünkü, ya tekrar kayıp giderse
Dialogue: 0,0:28:09.79,0:28:15.38,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}Sabah olmak üzere, güneş doğsa bile dağılmaz bu sis, kalır üzerimde
Dialogue: 0,0:28:15.38,0:28:20.88,ED5,,0,0,0,,{\blur6\bord0\c&H2B1111&}O belirsiz silüeti, titrek çizgileri adım adım izlerim
Dialogue: 0,0:28:20.88,0:28:24.55,ED5,,0,0,0,,{\blur6\bord0\fade(0,500)\c&H2B1111&}Yürürüm gerçeğe
