Dialogue: 0,0:00:05.79,0:00:07.75,Main,Fushiguro,0,0,0,,Bölgesel Genişleme:
Dialogue: 0,0:00:07.75,0:00:09.78,Main,Fushiguro,0,0,0,,Kimera Gölge Bahçesi.
Dialogue: 0,0:00:16.09,0:00:18.87,Main,Reggie,0,0,0,,İçrek Teknik: Farazi Hasır Sepet.
Dialogue: 0,0:00:21.20,0:00:26.84,Narration,Narrator,0,0,0,,'Basit Bölge', Farazi Hasır Sepet'in\N kökeninden gelmektedir.
Dialogue: 0,0:00:26.84,0:00:28.97,Narration,Narrator,0,0,0,,Bir bölgeyi nötrleme
Dialogue: 0,0:00:28.97,0:00:32.49,Narration,Narrator,0,0,0,,ve de kesin vuruş etkisini\N geçersiz kılmaya olanak sağlar.
Dialogue: 0,0:00:32.49,0:00:34.48,Main,Reggie,0,0,0,,Yazık oldu sana!
Dialogue: 0,0:00:35.18,0:00:38.79,Narration,Narrator,0,0,0,,Eğer Jogo ve Hanami isteseydi Shibuya'da\N kullandıkları 'Bölgesel Kuvvetlendirme'ye
Dialogue: 0,0:00:38.79,0:00:43.26,Narration,Narrator,0,0,0,,kesin vuruşlu ve kesin ölümlü bir teknik\N entegre edebilirdi.
Dialogue: 0,0:00:45.85,0:00:47.86,Italics,Reggie,0,0,0,,Nasıl vurabiliyor?
Dialogue: 0,0:00:47.86,0:00:51.16,Narration,Narrator,0,0,0,,Ancak bilerek kendi\N lanetli tekniklerini entegre etmediler
Dialogue: 0,0:00:51.16,0:00:55.07,Narration,Narrator,0,0,0,,ki bu sayede de Gojo'nun lanetli tekniğini\N emebilecekleri bir boşluk yaratıp
Dialogue: 0,0:00:55.07,0:00:57.16,Narration,Narrator,0,0,0,,onun Sonsuzluk'unu nötrlediler.
Dialogue: 0,0:00:57.44,0:01:00.08,Narration,Narrator,0,0,0,,Lakin Farazi Hasır Sepet ve Basit Bölge
Dialogue: 0,0:01:00.08,0:01:03.50,Narration,Narrator,0,0,0,,lanetli teknikleri doğrudan nötrlemezler.
Dialogue: 0,0:01:03.84,0:01:07.89,Narration,Narrator,0,0,0,,Bu tekniklerin olayı, lanetli tekniğin\N aktarıldığı bariyeri nötrlemek
Dialogue: 0,0:01:07.89,0:01:12.34,Narration,Narrator,0,0,0,,ve de bu sayede kesin vuruş\N etkisini ortadan kaldırmak.
Dialogue: 0,0:01:14.88,0:01:18.40,Narration,Narrator,0,0,0,,Velakin Fushiguro'nun bölgesi tam değildi.
Dialogue: 0,0:01:18.40,0:01:20.50,Main,Fushiguro,0,0,0,,O sinsi gülüşün kayboldu bakıyorum.
Dialogue: 0,0:01:20.50,0:01:22.27,Main,Reggie,0,0,0,,Sokuk velet!
Dialogue: 0,0:01:23.96,0:01:29.41,Narration,Narrator,0,0,0,,Salondaki boşluğa bölgesini yayarak
Dialogue: 0,0:01:29.41,0:01:31.75,Narration,Narrator,0,0,0,,bariyer misali kullanabildi
Dialogue: 0,0:01:31.75,0:01:34.61,Narration,Narrator,0,0,0,,fakat lanetli tekniğini,\N kesin vuruş olarak aktaramadı.
Dialogue: 0,0:01:36.24,0:01:38.19,Main,Reggie,0,0,0,,Kazandın sanma ulan!
Dialogue: 0,0:01:39.48,0:01:41.09,Italics,Reggie,0,0,0,,Anladım şimdi.
Dialogue: 0,0:01:41.09,0:01:42.95,Narration,Narrator,0,0,0,,Kimera Gölge Bahçesi
Dialogue: 0,0:01:42.95,0:01:47.17,Narration,Narrator,0,0,0,,şu anda On Gölge Tekniğini genişleterek
Dialogue: 0,0:01:47.17,0:01:52.07,Narration,Narrator,0,0,0,,saklı potansiyelinin\N %120'sini ortaya çıkarıyor.
Dialogue: 0,0:01:52.58,0:01:54.96,Narration,Narrator,0,0,0,,İşte tam da bu noksan
Dialogue: 0,0:01:54.96,0:01:57.55,Narration,Narrator,0,0,0,,Reggie Star'ı ansızın yakalayandı.
Dialogue: 0,0:01:57.55,0:02:02.13,Italics,Reggie,0,0,0,,Klonları da shikigamileri de\N bana saldırmadan önce fiziksel hâle bürünüyor.
Dialogue: 0,0:02:02.13,0:02:03.66,Italics,Reggie,0,0,0,,Demektir ki bu bariyerde
Dialogue: 0,0:02:03.66,0:02:06.14,Italics,Reggie,0,0,0,,lanetli tekniğinin kesin vuruş etkisi yok!
Dialogue: 0,0:02:06.52,0:02:10.62,Italics,Reggie,0,0,0,,Bölgesinin tekniğine olan artıları\N şakaya gelecek şey değil gerçi.
Dialogue: 0,0:02:10.62,0:02:14.00,Italics,Reggie,0,0,0,,Öylesi yalın kesin vuruşlu bir bölgeden\N daha bile tehlikeli bu!
Dialogue: 0,0:02:14.00,0:02:17.83,Italics,Reggie,0,0,0,,Olur da şu filini çağırıp\N beni suyla sırılsıklam ederse
Dialogue: 0,0:02:17.83,0:02:20.96,Italics,Reggie,0,0,0,,taktiklerimi yarılatır, mağlup eder beni.
Dialogue: 0,0:02:28.58,0:02:29.95,Italics,Reggie,0,0,0,,Ama...
Dialogue: 0,0:02:29.95,0:02:32.15,Italics,Reggie,0,0,0,,bunun olmamasını sağlamak da
Dialogue: 0,0:02:32.15,0:02:35.01,Italics,Reggie,0,0,0,,bana kalan kısım işte ya.
Dialogue: 0,0:02:35.97,0:02:37.01,Main,Fushiguro,0,0,0,,Nue!
Dialogue: 0,0:02:41.81,0:02:43.37,Main,Reggie,0,0,0,,Yavaşsın!
Dialogue: 0,0:02:47.06,0:02:48.78,Main,Reggie,0,0,0,,Biliyordum işte.
Dialogue: 0,0:02:50.98,0:02:53.30,Main,Reggie,0,0,0,,Bir süredir
Dialogue: 0,0:02:53.30,0:02:57.32,Main,Reggie,0,0,0,,yutulmamak için lanetli enerjiyle\N ayaklarımı güçlendirmek zorundaydım.
Dialogue: 0,0:03:00.75,0:03:05.28,Main,Reggie,0,0,0,,Bu bölgenin altı tamamen senin gölgen, di' mi?
Dialogue: 0,0:03:05.29,0:03:10.44,Main,Reggie,0,0,0,,Nesneleri saklayıp çıkarıyorsun, kendini de\N ne kullanışlı bi' şey böyle.
Dialogue: 0,0:03:10.44,0:03:13.18,Main,Reggie,0,0,0,,Ama aklıma ne geldi bak.
Dialogue: 0,0:03:13.18,0:03:15.69,Main,Reggie,0,0,0,,"Fazla silahı yok herifin."
Dialogue: 0,0:03:15.69,0:03:19.01,Main,Reggie,0,0,0,,Kıçı kırık bi' lanetli silah\N kullandığını gördüm yalnızca.
Dialogue: 0,0:03:19.01,0:03:20.65,Main,Reggie,0,0,0,,Ya kapasiten azdı
Dialogue: 0,0:03:20.65,0:03:25.23,Main,Reggie,0,0,0,,ve de kendini saklamak için gerekli boşluk gerekiyodu
Dialogue: 0,0:03:25.23,0:03:31.73,Main,Reggie,0,0,0,,ya da gölgenin içinde sakladığın şeylerin\N ağırlığını üstlenme yükümlülüğün vardı.
Dialogue: 0,0:03:33.50,0:03:35.48,Main,Reggie,0,0,0,,İkincisinde tombalayı tutturdum işte!
Dialogue: 0,0:03:35.90,0:03:39.49,Main,Reggie,0,0,0,,Bölgeni aldım, evirdim, sana çevirdim.
Dialogue: 0,0:03:39.49,0:03:44.41,Main,Reggie,0,0,0,,Şu üç arabayla da mevcut ağırlığın 2.4 ton olmalı.
Dialogue: 0,0:03:44.81,0:03:47.21,Main,Reggie,0,0,0,,Klonların dayanacak hâlde değil gibi
Dialogue: 0,0:03:47.21,0:03:50.42,Main,Reggie,0,0,0,,shikigamilerin ne âlemde ama?
Dialogue: 0,0:03:51.16,0:03:54.45,Main,Reggie,0,0,0,,Neyse ne, ayaklarımı kuvvetlendirmeye devam edip
Dialogue: 0,0:03:54.45,0:03:58.96,Main,Reggie,0,0,0,,ezim ezim ezil diye ağırlık eklemeye\N devam etmem gerek yalnızca.
Dialogue: 0,0:04:01.47,0:04:03.75,Main,Fushiguro,0,0,0,,Bir şeyi gözden kaçırmıyor musun?
Dialogue: 0,0:04:03.75,0:04:05.15,Main,Reggie,0,0,0,,Ha?
Dialogue: 0,0:04:05.15,0:04:08.70,Main,Fushiguro,0,0,0,,Tam olmasa da bölge bölgedir!
Dialogue: 0,0:04:10.35,0:04:11.76,Main,Fushiguro,0,0,0,,TEPEN DE {\alpha&HFF&}GÖLGE ULAN!
Dialogue: 0,0:04:11.76,0:04:12.94,Main,Fushiguro,0,0,0,,TEPEN DE GÖLGE ULAN!
Dialogue: 0,0:04:24.74,0:04:27.19,Main,Fushiguro,0,0,0,,HANGİMİZ ÖNCE EZİLECEK...
Dialogue: 0,0:04:27.76,0:04:29.26,Main,Fushiguro,0,0,0,,REGGİE!
Dialogue: 0,0:06:03.83,0:06:09.17,Narration,Narrator,0,0,0,,Sıradan bir insan beş ila altı G kuvvetine\N maruz kaldığında bilincini kaybettiği söylenir.
Dialogue: 0,0:06:09.83,0:06:11.57,Narration,Narrator,0,0,0,,2.4 ton.
Dialogue: 0,0:06:12.17,0:06:15.32,Narration,Narrator,0,0,0,,60 kilo olan Fushiguro
Dialogue: 0,0:06:15.32,0:06:19.47,Narration,Narrator,0,0,0,,şu anda 40 G'nin altında ezilmek suretinde.
Dialogue: 0,0:06:20.26,0:06:24.08,Narration,Narrator,0,0,0,,Yüksek G kuvvetinden ötürü\N kanı bacaklarına birikmesin diye
Dialogue: 0,0:06:24.08,0:06:27.20,Narration,Narrator,0,0,0,,ve de beynine giden kan akışı kesilmesin diye
Dialogue: 0,0:06:27.20,0:06:29.64,Narration,Narrator,0,0,0,,Fushiguro alçak vaziyette duruyor.
Dialogue: 0,0:06:29.64,0:06:31.92,Narration,Narrator,0,0,0,,Bacaklarına öncelik vererek
Dialogue: 0,0:06:31.92,0:06:34.78,Narration,Narrator,0,0,0,,vücudunu lanetli enerjiyle kuvvetlendiriyordu.
Dialogue: 0,0:06:36.06,0:06:40.53,Narration,Narrator,0,0,0,,Olgun bir Afrika fili üç ila altı ton arasıdır.
Dialogue: 0,0:06:41.93,0:06:45.21,Narration,Narrator,0,0,0,,Bölgesi sayesinde tekniği üzerindeki\N hassasiyetinin artmasıyla
Dialogue: 0,0:06:45.21,0:06:48.59,Narration,Narrator,0,0,0,,Maksimum Fil, şüphesiz ki\N gerçek ağırlığıyla tezahür etti.
Dialogue: 0,0:06:48.92,0:06:54.82,Narration,Narrator,0,0,0,,Bu ağırlığı sırtlanan Reggie Star'ın\N sağ broşu ve de topuk kemiği çatladı.
Dialogue: 0,0:06:56.03,0:06:58.76,Narration,Narrator,0,0,0,,İki taraf da
Dialogue: 0,0:06:58.76,0:07:02.62,Narration,Narrator,0,0,0,,her an nalları dikebilecekleri\Nbir ihtimale kafa tutuyor.
Dialogue: 0,0:07:04.07,0:07:06.00,Italics,Reggie,0,0,0,,Sıçtım batırdım!
Dialogue: 0,0:07:06.00,0:07:08.84,Italics,Reggie,0,0,0,,Kamyonları çarçur etmesem kesin kazanmıştım!
Dialogue: 0,0:07:08.84,0:07:10.33,Italics,Reggie,0,0,0,,N'apacağım?
Dialogue: 0,0:07:10.33,0:07:13.06,Italics,Reggie,0,0,0,,Bir yandan da üzerime üzerime su geliyor
Dialogue: 0,0:07:13.06,0:07:15.00,Italics,Reggie,0,0,0,,ama asıl kozumu hâlâ yitirmedim.
Dialogue: 0,0:07:15.00,0:07:19.04,Italics,Reggie,0,0,0,,Gölgenin içine dalıp kozumu oynayabilirim.
Dialogue: 0,0:07:19.04,0:07:21.44,Italics,Reggie,0,0,0,,Bu sefer kesin ezilir gider!
Dialogue: 0,0:07:23.39,0:07:24.43,Italics,Reggie,0,0,0,,Hayır...
Dialogue: 0,0:07:24.43,0:07:26.82,Italics,Reggie,0,0,0,,Şu anda bölgesini iptal etmiyorsa
Dialogue: 0,0:07:26.82,0:07:32.38,Italics,Reggie,0,0,0,,demektir ki bölgenin içine hapsolan şeyler bölge kapandıktan sonra dahi orada sıkışıyor!
Dialogue: 0,0:07:32.83,0:07:36.93,Italics,Reggie,0,0,0,,Ya herif geberdiğinde bölgenin içinde\N sonsuza kadar tıkılı kalırsam?
Dialogue: 0,0:07:37.56,0:07:40.07,Italics,Reggie,0,0,0,,Gölgesinin içi nasıl ki hem?
Dialogue: 0,0:07:40.07,0:07:43.04,Italics,Reggie,0,0,0,,Sıvı gibi duruyor da nefes alınabilir mi?
Dialogue: 0,0:07:43.04,0:07:44.06,Italics,Reggie,0,0,0,,Yüzebilir miyim?
Dialogue: 0,0:07:44.51,0:07:48.56,Italics,Reggie,0,0,0,,Olmaz böyle. Gölgesine batmak fazla riskli.
Dialogue: 0,0:07:48.56,0:07:51.37,Italics,Reggie,0,0,0,,O zaman bu hâldeyken...
Dialogue: 0,0:07:52.16,0:07:55.55,Italics,Reggie,0,0,0,,Kozumu çıkartıp oynamam şarttır artık!
Dialogue: 0,0:07:59.52,0:08:02.62,Main,Reggie,0,0,0,,Sözleşmeli Yeniden İnşa!
Dialogue: 0,0:08:22.40,0:08:24.11,Italics,Reggie,0,0,0,,Tutturamadım zamanlamayı!
Dialogue: 0,0:08:24.11,0:08:27.26,Italics,Reggie,0,0,0,,Gölgesinin içinde oksijen de yok hem!
Dialogue: 0,0:08:28.71,0:08:31.54,Italics,Reggie,0,0,0,,Kaldırma kuvveti de, basınç da yok!
Dialogue: 0,0:08:34.24,0:08:38.90,Italics,Reggie,0,0,0,,Öylece... batıyorum!
Dialogue: 0,0:08:40.04,0:08:43.79,Italics,Reggie,0,0,0,,Bilincim... yitiyor...
Dialogue: 0,0:08:49.49,0:08:51.85,Italics,Fushiguro,0,0,0,,Daha değil! Az daha dayanmalıyım!
Dialogue: 0,0:08:51.85,0:08:54.72,Italics,Fushiguro,0,0,0,,Herifin öldüğünden emin olana dek devam etmeliyim!
Dialogue: 0,0:08:54.72,0:08:57.60,Italics,Fushiguro,0,0,0,,Sonrasında gölgemdekileri defederim!
Dialogue: 0,0:09:30.18,0:09:32.71,Main,Reggie,0,0,0,,Yeniden yarattığım şeyler
Dialogue: 0,0:09:32.71,0:09:36.92,Main,Reggie,0,0,0,,onlara verdiğim emri yerine\N getirdikleri vakit kayboluyorlar.
Dialogue: 0,0:09:36.92,0:09:40.18,Main,Reggie,0,0,0,,Batırdığım arabalara herhangi bir\N emir vermedim ama.
Dialogue: 0,0:09:40.18,0:09:43.43,Main,Reggie,0,0,0,,Yok olsunlar istemedim nitekim.
Dialogue: 0,0:09:43.43,0:09:46.51,Main,Reggie,0,0,0,,Bu da demektir ki hâlâ daha emir verebilirim.
Dialogue: 0,0:09:46.51,0:09:49.33,Main,Reggie,0,0,0,,"Beni alıp yukarı çıkartın!" diye.
Dialogue: 0,0:09:49.33,0:09:53.90,Main,Reggie,0,0,0,,Tek arabanın ağırlığı gitti de var olsun, yaşıyorum hâlâ.
Dialogue: 0,0:09:57.80,0:09:59.50,Main,Reggie,0,0,0,,Hakkını yemeyeyim bak.
Dialogue: 0,0:09:59.50,0:10:01.44,Main,Reggie,0,0,0,,Güçlüsün sen.
Dialogue: 0,0:10:01.95,0:10:03.47,Main,Reggie,0,0,0,,Ama ne var ki ben...
Dialogue: 0,0:10:05.14,0:10:07.27,Main,Reggie,0,0,0,,DAHA GÜÇLÜYÜM!
Dialogue: 0,0:10:07.27,0:10:10.79,Main,Reggie,0,0,0,,Sözleşmeli Yeniden İnşa!
Dialogue: 0,0:10:15.87,0:10:21.34,Main,Reggie,0,0,0,,12 METREKARELİK İKİ KATLI\N AHŞAP ŞASİLİ MÜSTAKİL EV!
Dialogue: 0,0:10:21.34,0:10:24.77,Main,Reggie,0,0,0,,ŞASİSİ BİR BAŞINA OTUZ TON EDİYOR ZATEN!
Dialogue: 0,0:10:24.77,0:10:27.61,Main,Reggie,0,0,0,,EZİL GİT ULAAAN!
Dialogue: 0,0:11:00.47,0:11:02.24,Italics,Reggie,0,0,0,,Ne oldu şimdi?
Dialogue: 0,0:11:02.24,0:11:04.81,Italics,Reggie,0,0,0,,Tekrar mı gölgesine battım?
Dialogue: 0,0:11:06.09,0:11:07.50,Italics,Reggie,0,0,0,,Yok!
Dialogue: 0,0:11:07.50,0:11:09.16,Italics,Reggie,0,0,0,,Gerçek suyun içindeyim şu anda!
Dialogue: 0,0:11:09.16,0:11:10.15,Italics,Reggie,0,0,0,,Nasıl oldu?
Dialogue: 0,0:11:11.18,0:11:12.32,Italics,Reggie,0,0,0,,Ağır be!
Dialogue: 0,0:11:12.32,0:11:15.11,Italics,Reggie,0,0,0,,Beni batıran bu velet mi?
Dialogue: 0,0:11:15.44,0:11:17.31,Italics,Reggie,0,0,0,,Güce gel ulan!
Dialogue: 0,0:11:17.31,0:11:19.05,Italics,Reggie,0,0,0,,Hayır, bekle!
Dialogue: 0,0:11:19.05,0:11:22.42,Italics,Reggie,0,0,0,,Yarattığım o iki araba yüzünden böyle güçlü!
Dialogue: 0,0:11:24.60,0:11:25.73,Italics,Reggie,0,0,0,,Kötü oldu...
Dialogue: 0,0:11:26.28,0:11:28.06,Italics,Reggie,0,0,0,,Bu sefer batıyorum!
Dialogue: 0,0:11:28.69,0:11:31.96,Italics,Reggie,0,0,0,,Sözleşmeli Yeniden İnşa'yı iptal etmem lazım!
Dialogue: 0,0:11:50.14,0:11:51.76,Italics,Reggie,0,0,0,,Doğru!
Dialogue: 0,0:11:51.76,0:11:53.76,Italics,Reggie,0,0,0,,Belediye salonu burası!
Dialogue: 0,0:11:53.76,0:11:56.97,Italics,Reggie,0,0,0,,Ve spor salonunun bodrum katı\Nısıtmalı bir yüzme havuzu!
Dialogue: 0,0:11:59.79,0:12:02.57,Italics,Reggie,0,0,0,,Gölgesine kaçıp bölgesini bozup
Dialogue: 0,0:12:02.57,0:12:06.31,Italics,Reggie,0,0,0,,zemini bana yıktırarak\Nhavuza düşmemi sağladı demek!
Dialogue: 0,0:12:09.75,0:12:13.08,Main,Fushiguro,0,0,0,,Fişlerin sırılsıklamken bir halta yaramaz, haksız mıyım?
Dialogue: 0,0:12:17.19,0:12:20.59,Italics,Reggie,0,0,0,,Çabucak kovalamaktansa bekleyivermiş.
Dialogue: 0,0:12:20.59,0:12:24.01,Italics,Reggie,0,0,0,,Bölgesinden sonra yorulan tekniğini yeniliyor olmalı.
Dialogue: 0,0:12:24.87,0:12:27.98,Main,Reggie,0,0,0,,Bilmem... Öyle mi ki?
Dialogue: 0,0:12:28.74,0:12:32.47,Main,Reggie,0,0,0,,Sana sormalı,\N daha da shikigami kullanamıyorsundur kesin.
Dialogue: 0,0:12:33.65,0:12:35.16,Main,Fushiguro,0,0,0,,Aynen öyle.
Dialogue: 0,0:12:35.16,0:12:38.14,Main,Fushiguro,0,0,0,,Anlamışsındır herhalde... sırada ne olacağını.
Dialogue: 0,0:12:39.65,0:12:43.26,Italics,Reggie,0,0,0,,O köpeğinden gayrı bi' shikigami kullanacak!
Dialogue: 0,0:12:43.26,0:12:45.54,Italics,Reggie,0,0,0,,Ama hiçbiri de sağlam bi' hamle yapamaz.
Dialogue: 0,0:12:45.54,0:12:47.35,Italics,Reggie,0,0,0,,Buyur kullan!
Dialogue: 0,0:12:47.35,0:12:51.16,Italics,Reggie,0,0,0,,Azıcık gevşe, karşı saldırımla harcayacağım seni!
Dialogue: 0,0:13:41.60,0:13:46.37,Main,Fushiguro,0,0,0,,İlahi Köpekler azıcık yarayla bitecek kadar zayıf değil.
Dialogue: 0,0:13:47.38,0:13:52.01,Main,Reggie,0,0,0,,Sahirlerde yalan mübahtı ha?..
Dialogue: 0,0:14:08.14,0:14:09.97,Main,Reggie,0,0,0,,Bölge...
Dialogue: 0,0:14:09.97,0:14:11.18,Main,Reggie,0,0,0,,havuz...
Dialogue: 0,0:14:11.83,0:14:16.38,Main,Reggie,0,0,0,,Hepsi sırf şu köpeğini kullanamadığına inandırmak içindi.
Dialogue: 0,0:14:16.38,0:14:20.16,Main,Reggie,0,0,0,,Salona kaçmadın yani.
Dialogue: 0,0:14:20.16,0:14:21.80,Main,Reggie,0,0,0,,Yemledin.
Dialogue: 0,0:14:22.40,0:14:24.45,Main,Reggie,0,0,0,,Modern zamandan bir sahirin
Dialogue: 0,0:14:24.45,0:14:28.34,Main,Reggie,0,0,0,,ve de böylesi bir veledin beni alt etmesi...
Dialogue: 0,0:14:30.00,0:14:33.83,Main,Fushiguro,0,0,0,,Kaçmak isteseydim de Nue\N birini uzun süre taşıyarak uçamıyor.
Dialogue: 0,0:14:33.83,0:14:36.10,Main,Fushiguro,0,0,0,,Acı şekilde öğrenmiştim.
Dialogue: 0,0:14:41.82,0:14:45.71,Main,Fushiguro,0,0,0,,Tengen-sama'yla alakan nedir?
Dialogue: 0,0:14:49.61,0:14:51.43,Main,Reggie,0,0,0,,Tengen mi?
Dialogue: 0,0:14:52.45,0:14:55.08,Main,Reggie,0,0,0,,Ah, doğru ya.
Dialogue: 0,0:14:55.08,0:14:57.37,Main,Reggie,0,0,0,,Hâlâ hayatta demek ha?
Dialogue: 0,0:14:58.07,0:15:00.35,Main,Reggie,0,0,0,,O asosyal.
Dialogue: 0,0:15:00.35,0:15:02.34,Main,Fushiguro,0,0,0,,Öyle mi? Bu kadarı yeter.
Dialogue: 0,0:15:04.24,0:15:08.34,Italics,Fushiguro,0,0,0,,Reggie dedi ki Tengen-sama'nın İtlaf Oyunu'nun\N emeli hakkındaki iddiaları blöfmüş.
Dialogue: 0,0:15:09.24,0:15:12.34,Italics,Fushiguro,0,0,0,,Tengen-sama ve Kenjaku'nun gizli bir bağlantısı olduğunu
Dialogue: 0,0:15:12.34,0:15:16.33,Italics,Fushiguro,0,0,0,,ve de amaçları hakkında yalan\N söylediklerini düşünmeliyimdir de...
Dialogue: 0,0:15:17.00,0:15:19.24,Italics,Fushiguro,0,0,0,,onun tepkisinden böyle olmadığını sanıyorum.
Dialogue: 0,0:15:23.41,0:15:28.88,Main,Reggie,0,0,0,,Kogane, şuna puanlarımın hepsini ver gitsin.
Dialogue: 0,0:15:29.36,0:15:30.58,Main,Kogane,0,0,0,,Timam!
Dialogue: 0,0:15:32.03,0:15:36.34,Main,Kogane,0,0,0,,Reggie Star'dan hanenize 41 puan eklendi.
Dialogue: 0,0:15:36.34,0:15:37.82,Main,Fushiguro,0,0,0,,Amacın ne senin?
Dialogue: 0,0:15:38.55,0:15:41.46,Main,Reggie,0,0,0,,İnsan teşekkür eder.
Dialogue: 0,0:15:41.46,0:15:44.27,Main,Reggie,0,0,0,,Gebermeden bi' hayrım olsun dedim.
Dialogue: 0,0:15:44.97,0:15:47.70,Main,Reggie,0,0,0,,Seyircinin tekiyim ben.
Dialogue: 0,0:15:47.70,0:15:50.35,Main,Reggie,0,0,0,,Kenjaku'yla sıkı fıkı falan değilim.
Dialogue: 0,0:15:50.88,0:15:54.43,Main,Reggie,0,0,0,,Bunu yapmanın işleri\Nilginçleştireceğini düşünüyorum.
Dialogue: 0,0:15:54.94,0:15:56.82,Main,Reggie,0,0,0,,Öyle sezdim yani.
Dialogue: 0,0:15:58.28,0:16:00.19,Main,Reggie,0,0,0,,Hadi göreyim seni!
Dialogue: 0,0:16:00.19,0:16:02.66,Main,Reggie,0,0,0,,Neticede beni öldürdün.
Dialogue: 0,0:16:03.31,0:16:10.31,Main,Reggie,0,0,0,,Kaderin cilvesine yenik düşüp aptal gibi geber git.
Dialogue: 0,0:16:33.16,0:16:35.79,Main,Kogane,0,0,0,,Hanenize beş puan eklendi.
Dialogue: 0,0:16:48.86,0:16:50.18,Main,Hazenoki,0,0,0,,Başardım mı?
Dialogue: 0,0:16:50.71,0:16:52.89,Main,Takaba,0,0,0,,Hayır! Gardını indirme sakın!
Dialogue: 0,0:16:54.43,0:16:55.82,Main,Takaba,0,0,0,,Herif sağlam!
Dialogue: 0,0:16:55.82,0:16:57.41,Main,Hazenoki,0,0,0,,Ne oluyor lan?
Dialogue: 0,0:16:56.41,0:16:57.41,Sign_Basic,Screen,0,0,0,,{\c&H73511F&\3c&HFFFFFF&\shad0\bord0\fs54\pos(1196.001,249.999)\fnArial}Fışk
Dialogue: 0,0:16:57.84,0:16:59.99,Main,Hazenoki,0,0,0,,Neden losyonla kaplısın ulan?
Dialogue: 0,0:16:59.99,0:17:01.45,Main,Takaba,0,0,0,,Salça olmasın mı?
Dialogue: 0,0:17:01.45,0:17:02.92,Main,Hazenoki,0,0,0,,Kes ulan! Geber!
Dialogue: 0,0:17:04.47,0:17:07.12,Main,Hazenoki,0,0,0,,Bekle harbi salça ulan bu!
Dialogue: 0,0:17:07.39,0:17:08.19,Italics,Hazenoki,0,0,0,,Sıçayım!
Dialogue: 0,0:17:08.19,0:17:10.11,Italics,Hazenoki,0,0,0,,Harbi diyorum ne bu herif böyle?
Dialogue: 0,0:17:10.11,0:17:12.24,Italics,Hazenoki,0,0,0,,Kaç defa havaya uçurdum adamı!
Dialogue: 0,0:17:12.24,0:17:14.44,Italics,Hazenoki,0,0,0,,En az beş kere ölmüş olması lazımdı!
Dialogue: 0,0:17:14.83,0:17:17.41,Italics,Hazenoki,0,0,0,,O hâlde nasıl oluyor da bu kadar az hasar alıyor?
Dialogue: 0,0:17:18.60,0:17:20.01,Main,Takaba,0,0,0,,Salça sevmez misin?
Dialogue: 0,0:17:20.52,0:17:23.24,Italics,Hazenoki,0,0,0,,İlk yarası da iyileşmiş bi' ara.
Dialogue: 0,0:17:23.74,0:17:27.72,Italics,Hazenoki,0,0,0,,Ama benim gibi ters lanetli teknik\N kullandığına da tanık olmadım.
Dialogue: 0,0:17:28.35,0:17:30.47,Italics,Hazenoki,0,0,0,,Kafam almıyor bunu!
Dialogue: 0,0:17:31.03,0:17:32.52,Main,Kogane,0,0,0,,Hazenoki-sama.
Dialogue: 0,0:17:32.52,0:17:33.83,Main,Hazenoki,0,0,0,,N'oldu?
Dialogue: 0,0:17:33.83,0:17:36.99,Main,Kogane,0,0,0,,Reggie Star-sama an itibariyle vefat etti.
Dialogue: 0,0:17:40.67,0:17:42.22,Main,Takaba,0,0,0,,Ah? Ne oldu?
Dialogue: 0,0:17:42.22,0:17:43.55,Main,Hazenoki,0,0,0,,Gidiyorum.
Dialogue: 0,0:17:43.55,0:17:44.92,Main,Hazenoki,0,0,0,,Bıktım usandım.
Dialogue: 0,0:17:44.92,0:17:46.01,Main,Takaba,0,0,0,,Demek öyle!
Dialogue: 0,0:17:46.01,0:17:47.14,Main,Takaba,0,0,0,,Duşunu da al!
Dialogue: 0,0:17:47.14,0:17:48.46,Main,Takaba,0,0,0,,Dişlerini de fırçala bak!
Dialogue: 0,0:17:51.35,0:17:54.00,Main,Takaba,0,0,0,,Baksana genç! Puanlarını alayım mı?
Dialogue: 0,0:17:54.44,0:17:55.67,Main,Hazenoki,0,0,0,,Git peşimden.
Dialogue: 0,0:17:55.67,0:17:59.36,Main,Takaba,0,0,0,,Hadi yaa! Kıyak geçiyormuşsun gibi düşün!
Dialogue: 0,0:17:59.36,0:18:00.35,Main,Hazenoki,0,0,0,,Geber.
Dialogue: 0,0:18:00.66,0:18:03.38,Narration,Narrator,0,0,0,,Takaba'nın lanetli tekniği 'Komedyen'
Dialogue: 0,0:18:03.38,0:18:07.76,Narration,Narrator,0,0,0,,Takaba'nın komik bulduğu\N her türlü fenomeni gerçekliğe döküyor.
Dialogue: 0,0:18:07.76,0:18:11.86,Narration,Narrator,0,0,0,,Gojo Satoru'nun tekniğine dahi muhalif bir teknik.
Dialogue: 0,0:18:13.44,0:18:18.37,Narration,Narrator,0,0,0,,Lakin Takaba'nın tekniğine dair gram bir fikri yok.
Dialogue: 0,0:18:26.79,0:18:28.82,Italics,Remi,0,0,0,,Anlamıyorum işte! Anlamıyorum!
Dialogue: 0,0:18:28.82,0:18:32.25,Italics,Remi,0,0,0,,İnsan büyüdükçe anlamadığı\N ne kadar çok şey oluyormuş meğer!
Dialogue: 0,0:18:37.92,0:18:40.75,Italics,Remi,0,0,0,,Tüm erkeklerin kurt olduğunu duymuştum
Dialogue: 0,0:18:40.75,0:18:44.93,Italics,Remi,0,0,0,,ama benim için tüm karmaşık şeylerle uğraşanlar da hep o kurtlar oldu işte!
Dialogue: 0,0:18:49.17,0:18:51.81,Italics,Remi,0,0,0,,O kurtlar her şeyle baş edecekse
Dialogue: 0,0:18:51.81,0:18:54.67,Italics,Remi,0,0,0,,benim hiçbir şeyden dert yanmama\N lüzum yok o zaman!
Dialogue: 0,0:18:54.67,0:18:57.36,Italics,Remi,0,0,0,,Tatlıyım da ondan işte!
Dialogue: 0,0:19:04.58,0:19:07.65,Italics,Remi,0,0,0,,Ama var ya kurtlar hep... hep...
Dialogue: 0,0:19:16.29,0:19:18.73,Italics,Tsumiki,0,0,0,,Yapma, Megumi.
Dialogue: 0,0:19:25.96,0:19:27.15,Main,Remi,0,0,0,,Emin misin?
Dialogue: 0,0:19:35.52,0:19:37.14,Main,Fushiguro,0,0,0,,Bi' sus be.
Dialogue: 0,0:19:40.46,0:19:42.45,Main,Fushiguro,0,0,0,,İllet abla.
Dialogue: 0,0:20:01.99,0:20:05.07,Narration - Top,Narrator,0,0,0,,Sendai Kolonisi'nde olaylar hızla gerçekleşti
Dialogue: 0,0:20:05.07,0:20:08.71,Narration - Top,Narrator,0,0,0,,Tokyo Kolonisi'ndekileri çoktan geride bıraktı
Dialogue: 0,0:20:08.71,0:20:10.42,Narration - Top,Narrator,0,0,0,,ortalık mahşer yerine döndü.
Dialogue: 0,0:20:12.66,0:20:17.27,Narration,Narrator,0,0,0,,Dhruv Lakdawalla. Mevcut puanı: 91.
Dialogue: 0,0:20:17.27,0:20:19.07,Narration,Narrator,0,0,0,,İkinci defa enkarne oluşu.
Dialogue: 0,0:20:19.80,0:20:25.27,Narration,Narrator,0,0,0,,Wa'daki iç savaşta takımadaları\N tek başına fethedebilmiş bir isim.
Dialogue: 0,0:20:22.51,0:20:25.27,Narration,Narrator,0,0,0,,
Dialogue: 0,0:20:25.87,0:20:28.34,Narration,Narrator,0,0,0,,Cephanesinde iki özerk shikigami barındırıyor
Dialogue: 0,0:20:28.34,0:20:32.57,Narration,Narrator,0,0,0,,ve o shikigamilerin yörüngesi, bölgesini belirliyor.
Dialogue: 0,0:20:35.51,0:20:40.03,Narration,Narrator,0,0,0,,İshigori Ryu. Mevcut puanı: 77.
Dialogue: 0,0:20:40.71,0:20:45.13,Narration,Narrator,0,0,0,,Oyuncular arasındaki en yüksek lanetli enerji\N çıkışına sahip canlı bir savaş topu.
Dialogue: 0,0:20:46.76,0:20:50.43,Narration,Narrator,0,0,0,,Uro Takako. Mevcut puanı: 70.
Dialogue: 0,0:20:51.13,0:20:54.12,Narration,Narrator,0,0,0,,Aslen Fujiwara Klanı'nın altında\N hüküm süren suikastçı ekipleri:
Dialogue: 0,0:20:54.12,0:20:56.73,Narration,Narrator,0,0,0,,Güneş, Ay ve Yıldızlar Takımlarının kaptanıydı.
Dialogue: 0,0:20:57.26,0:21:00.52,Narration,Narrator,0,0,0,,'Gökyüzü'nü manipüle etmesini sağlayan bir tekniğe evsahipliği yapıyor.
Dialogue: 0,0:21:01.74,0:21:06.02,Narration,Narrator,0,0,0,,Kurourushi. Mevcut puanı: 54.
Dialogue: 0,0:21:06.02,0:21:12.02,Narration,Narrator,0,0,0,,Kenjaku'nun Lanetli Ruh Manipülasyonu'ndan azat ettiği bir hamamböceği lanetli ruhu.
Dialogue: 0,0:21:08.86,0:21:12.02,Narration,Narrator,0,0,0,,
Dialogue: 0,0:21:12.02,0:21:15.88,Narration,Narrator,0,0,0,,Kademesi,—çoktan belirlendi—özel kademe.
Dialogue: 0,0:21:17.00,0:21:20.84,Narration,Narrator,0,0,0,,Belli koşullar sağlanana dek\N faaliyet göstermeyerek uyuyor.
Dialogue: 0,0:21:22.16,0:21:23.79,Narration,Narrator,0,0,0,,Aralarında ittifak söz konusu değil
Dialogue: 0,0:21:23.79,0:21:30.05,Narration,Narrator,0,0,0,,ancak uyum sağlama kabiliyetleri ve muhalif güçleri, onları dörtlü bir çıkmaza soktu.
Dialogue: 0,0:21:27.59,0:21:30.05,Narration,Narrator,0,0,0,,
Dialogue: 0,0:21:30.58,0:21:33.34,Narration,Narrator,0,0,0,,Velakin bu sütunlardan biri...
Dialogue: 0,0:21:34.79,0:21:36.16,Narration,Narrator,0,0,0,,devrildi.
Dialogue: 0,0:21:37.60,0:21:42.39,Narration,Narrator,0,0,0,,Okkotsu Yuta. Mevcut puanı: 35.
Dialogue: 0,0:21:43.04,0:21:45.48,Narration,Narrator,0,0,0,,Yüz İblisin Geçit Töreni'nden üç ay sonra
Dialogue: 0,0:21:45.48,0:21:47.98,Narration,Narrator,0,0,0,,özel kademe bir sahir olarak çiçek açtı.
Dialogue: 0,0:21:47.98,0:21:51.53,Narration,Narrator,0,0,0,,Gojo Satoru'yla boy ölçüşen, modern zamanın...
Dialogue: 0,0:21:51.53,0:21:53.07,Narration,Narrator,0,0,0,,dâhisi.
Dialogue: 0,0:23:26.55,0:23:28.40,Main,Okkotsu,0,0,0,,400 puanı bir başıma elde edeceğim.
Dialogue: 0,0:23:28.40,0:23:31.08,Main,Rika,0,0,0,,Yuta, hangisini istersin?
Dialogue: 0,0:23:31.08,0:23:32.31,Main,Kogane,0,0,0,,Kurourushi diyorlar!
Dialogue: 0,0:23:32.31,0:23:32.81,Main,Okkotsu,0,0,0,,Hepsini.
Dialogue: 0,0:23:32.81,0:23:35.34,Main,Rika,0,0,0,,Yuta'yı geri ver!
Dialogue: 0,0:23:35.34,0:23:38.43,Main,Okkotsu,0,0,0,,Sensei'ye can dostunu tekrar öldürtmeyeceğim.
Dialogue: 0,0:00:00.00,0:00:02.98,Ep_Title,Screen,0,0,0,,Bölüm 58\N{\fs90}1. Tokyo Kolonisi, 5. KISIM
