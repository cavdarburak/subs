Dialogue: 0,0:00:10.49,0:00:11.20,Show_Title,Screen,0,0,0,,{\c&H0200E9&\3c&H000000&}JUJUTSU KAISEN
Dialogue: 0,0:00:34.48,0:00:38.69,Show_Title,Screen,0,0,0,,{\fad(0,650)\c&H2E2C2C&}JUJUTSU KAISEN\N{\fs36\c&HF3F3F3&\bord0\alpha&HFF&\t(237,736,1\alpha&H00&)}İtlaf Oyunu 1. Kısım
Dialogue: 0,0:01:29.99,0:01:32.99,Ep_Title,Screen,0,0,0,,Bölüm 57\N{\fs90}1. Tokyo Kolonisi, 4. KISIM
Dialogue: 0,0:01:35.23,0:01:41.34,Main,Reggie,0,0,0,,Kuralların devamlılık fikri \Nsadece asıl plan için bir örtü.
Dialogue: 0,0:01:41.34,0:01:43.03,Main,Reggie,0,0,0,,Dediklerimi aklına kazı.
Dialogue: 0,0:01:43.42,0:01:45.70,Main,Reggie,0,0,0,,Sadece güçlüler ayakta kaldığında
Dialogue: 0,0:01:45.70,0:01:47.92,Main,Reggie,0,0,0,,Kenjaku, oyuna bi' bomba sallayacak
Dialogue: 0,0:01:47.92,0:01:51.13,Main,Reggie,0,0,0,,ve İtlaf Oyunu, amacına ulaşacak.
Dialogue: 0,0:01:51.71,0:01:55.32,Main,Reggie,0,0,0,,Kenjaku'nun ne tür bir\N bomba sallayacağı muamma.
Dialogue: 0,0:01:55.32,0:01:58.81,Main,Reggie,0,0,0,,Ama yakın zamanda gerçekleşecek bu.
Dialogue: 0,0:01:58.81,0:02:01.12,Main,Reggie,0,0,0,,Hatta belki şu anda.
Dialogue: 0,0:02:01.52,0:02:05.34,Main,Reggie,0,0,0,,İşte bu yüzdendir ki güçlü müttefikler\N ve de puan toplayarak
Dialogue: 0,0:02:05.34,0:02:07.32,Main,Reggie,0,0,0,,hazırlık yapıyorum.
Dialogue: 0,0:02:07.99,0:02:09.74,Main,Fushiguro,0,0,0,,Soracaklarım var.
Dialogue: 0,0:02:10.71,0:02:13.50,Main,Fushiguro,0,0,0,,Şunun o kadar güçlü\N olduğundan emin değilim.
Dialogue: 0,0:02:13.50,0:02:18.36,Main,Reggie,0,0,0,,O kadın uyduruk bahanelerle\N Oyuncular'ı buraya çeken bir yem sadece.
Dialogue: 0,0:02:18.36,0:02:21.26,Main,Reggie,0,0,0,,Kadınlara karşı daha az tetikte olurlar.
Dialogue: 0,0:02:22.06,0:02:23.41,Main,Fushiguro,0,0,0,,Onunla işin bittiğinde de
Dialogue: 0,0:02:23.41,0:02:25.62,Main,Fushiguro,0,0,0,,öldürüp puanlarını alacaksın, di' mi?
Dialogue: 0,0:02:27.19,0:02:28.88,Main,Reggie,0,0,0,,Ne diyorsun ya?
Dialogue: 0,0:02:28.88,0:02:30.80,Main,Reggie,0,0,0,,Yapmam ki öyle bi' şey.
Dialogue: 0,0:02:31.55,0:02:34.87,Main,Remi,0,0,0,,Reggie-sama benim hakiki şövalyemdir!
Dialogue: 0,0:02:34.87,0:02:38.14,Main,Remi,0,0,0,,Ona hizmet ettiğim müddetçe beni koruyacak!
Dialogue: 0,0:02:38.52,0:02:40.27,Main,Fushiguro,0,0,0,,Saf salaksın.
Dialogue: 0,0:02:40.71,0:02:44.38,Main,Fushiguro,0,0,0,,Sen ve müttefiklerinizin\N toplam puanı 100 eder mi?
Dialogue: 0,0:02:45.73,0:02:47.19,Main,Reggie,0,0,0,,Eder tabii.
Dialogue: 0,0:02:47.64,0:02:49.58,Main,Fushiguro,0,0,0,,Yakında yeni bir kural eklenecek.
Dialogue: 0,0:02:50.36,0:02:53.21,Main,Fushiguro,0,0,0,,Oyuncular'ın birbiri arasında puan transferi\N yapabilmesine olanak sağlayacak.
Dialogue: 0,0:02:54.63,0:02:58.32,Main,Fushiguro,0,0,0,,Puanlarını bana ver.
Dialogue: 0,0:02:58.32,0:03:00.95,Main,Reggie,0,0,0,,Müzakere biter.
Dialogue: 0,0:03:06.18,0:03:06.89,Main,Chizuru,0,0,0,,Kayboldu!
Dialogue: 0,0:03:09.68,0:03:10.64,Main,Chizuru,0,0,0,,LAN!
Dialogue: 0,0:03:11.10,0:03:12.05,Main,Fushiguro,0,0,0,,Nue!
Dialogue: 0,0:03:12.80,0:03:13.71,Main,Reggie,0,0,0,,Hoppala!
Dialogue: 0,0:03:15.14,0:03:15.98,Main,Fushiguro,0,0,0,,Bana bak!
Dialogue: 0,0:03:16.75,0:03:18.72,Main,Fushiguro,0,0,0,,Daha da görmeyeyim yüzünü.
Dialogue: 0,0:03:21.91,0:03:26.51,Main,Reggie,0,0,0,,Aaa doğru ya, doğru.
Dialogue: 0,0:03:27.08,0:03:30.47,Main,Reggie,0,0,0,,Bu yumuşak tavırların ne diyordum da\N öldüremiyormuşsun bizi.
Dialogue: 0,0:03:30.47,0:03:33.63,Main,Reggie,0,0,0,,Neticede gözün puanlarımızda.
Dialogue: 0,0:03:33.63,0:03:34.96,Main,Reggie,0,0,0,,Ama...
Dialogue: 0,0:03:35.60,0:03:38.21,Main,Reggie,0,0,0,,öldürmek için savaşmayacaksan
Dialogue: 0,0:03:38.21,0:03:40.96,Main,Reggie,0,0,0,,mortoyu çektiğinde gelip bana ağlama.
Dialogue: 0,0:04:05.46,0:04:06.74,Main,Reggie,0,0,0,,ALO!
Dialogue: 0,0:04:06.74,0:04:08.82,Main - Top,Reggie,0,0,0,,BEN DE BURADAYIM LAN!
Dialogue: 0,0:04:08.23,0:04:10.73,Sign_Basic,Screen,0,0,0,,{\pos(960,930)\fnTimes New Roman\b1\bord0\shad0\fs54\1a&H44&}Hazenoki İori, Mevcut Puanı: 35
Dialogue: 0,0:04:09.35,0:04:10.45,Main - Top,Iori,0,0,0,,Geberdi mi?
Dialogue: 0,0:04:19.04,0:04:20.40,Main,Fushiguro,0,0,0,,TAMAM MISIN BUNA?!
Dialogue: 0,0:04:23.31,0:04:24.29,Italics,Fushiguro,0,0,0,,Bu koku!
Dialogue: 0,0:04:39.06,0:04:40.55,Main - Top,Reggie,0,0,0,,Bitti mi?
Dialogue: 0,0:04:39.13,0:04:40.93,Sign_Basic,Screen,0,0,0,,{\pos(960,930)\fnTimes New Roman\b1\bord0\shad0\fs54\1a&H44&}Reggie Star, Mevcut Puanı: 41
Dialogue: 0,0:04:41.48,0:04:42.68,Main,Iori,0,0,0,,Daha değil.
Dialogue: 0,0:04:42.68,0:04:46.98,Main,Iori,0,0,0,,Senin gibi patlamadan önce\Nodaya tıkıştırdı kendini.
Dialogue: 0,0:04:48.30,0:04:50.27,Main,Reggie,0,0,0,,Fena değilmiş.
Dialogue: 0,0:04:50.27,0:04:53.10,Main,Reggie,0,0,0,,Ama payını verdin gibi sanki, di' mi?
Dialogue: 0,0:05:00.64,0:05:02.27,Main,Fushiguro,0,0,0,,Anladın mı artık!
Dialogue: 0,0:05:03.21,0:05:05.86,Main,Fushiguro,0,0,0,,Seni koruma niyetinde değiller.
Dialogue: 0,0:05:08.45,0:05:11.39,Main,Fushiguro,0,0,0,,Anladıysan kalk ayağa kaybol.
Dialogue: 0,0:05:19.02,0:05:20.79,Main,Fushiguro,0,0,0,,Bi' rahat ver artık.
Dialogue: 0,0:05:21.78,0:05:24.83,Main,Remi,0,0,0,,O zaman söyle.
Dialogue: 0,0:05:26.01,0:05:28.67,Main,Remi,0,0,0,,REGGİE-SAMA SÖYLEMİŞTİ!
Dialogue: 0,0:05:28.67,0:05:30.68,Main,Remi,0,0,0,,Beni koruyacağını!
Dialogue: 0,0:05:30.68,0:05:32.79,Main,Remi,0,0,0,,BENİ SEVDİĞİNİ!
Dialogue: 0,0:05:32.79,0:05:34.53,Main,Remi,0,0,0,,SEN DE SÖYLE!
Dialogue: 0,0:05:40.12,0:05:41.82,Main,Fushiguro,0,0,0,,Ara sıra da olsa—
Dialogue: 0,0:05:42.66,0:05:45.06,Main,Fushiguro,0,0,0,,senin gibi, icraatten çok...
Dialogue: 0,0:05:45.63,0:05:48.65,Main,Fushiguro,0,0,0,,lafa bakan şerefsizlere rastlıyorsun.
Dialogue: 0,0:05:48.65,0:05:50.97,Main,Chizuru,0,0,0,,Demin beni aşağı attığın için sağ ol...
Dialogue: 0,0:05:51.94,0:05:54.06,Main - Top,Chizuru,0,0,0,,ama şimdi haşatın çıktı.
Dialogue: 0,0:05:53.79,0:05:58.38,Sign_Basic,Screen,0,0,0,,{\pos(960,930)\fnTimes New Roman\b1\bord3\shad0\fs54\1a&H44&\3a&H88&\be6}Hari Chizuru, Mevcut Puanı: 28
Dialogue: 0,0:05:54.46,0:05:56.98,Main - Top,Chizuru,0,0,0,,Buraya çıkana kadar öldüm bittim.
Dialogue: 0,0:05:56.98,0:05:59.42,Main - Top,Fushiguro,0,0,0,,Merdivenleri kullansaydın mağara ayısı.
Dialogue: 0,0:05:59.42,0:06:02.72,Main,Kogane,0,0,0,,Ding-dong, ding-dong, ding-dong, \Nding-dong, ding-dong!
Dialogue: 0,0:06:02.72,0:06:07.51,Main,Kogane,0,0,0,,Bir Oyuncu, İtlaf Oyunu'na yeni bir kural ekledi!
Dialogue: 0,0:06:07.51,0:06:07.87,Onscreen2,Screen,0,0,0,,{\an8\3a&H00&}9: Oyuncular, sırayla başka oyuncuların\N şu özelliklerini görüntüleyebilir: \N isim, puan, eklenen kural sayısı ve mevcut Koloni'si.
Dialogue: 0,0:06:07.87,0:06:14.02,Onscreen2,Screen,0,0,0,,{\an8\fad(300,0)\3a&H00&}10: Oyuncular dilediği miktarda puanı\N seçtiği Oyuncu'ya transfer edebilir.
Dialogue: 0,0:06:08.49,0:06:12.67,Main,Kogane,0,0,0,,10. Kural: Oyuncular dilediği miktarda puanı
Dialogue: 0,0:06:12.67,0:06:14.80,Main,Kogane,0,0,0,,seçtiği Oyuncu'ya transfer edebilir.
Dialogue: 0,0:06:15.17,0:06:17.80,Main,Chizuru,0,0,0,,Bu nasıl kural ulan?
Dialogue: 0,0:06:50.91,0:06:52.06,Main,Fushiguro,0,0,0,,Maksimum Fil!
Dialogue: 0,0:06:54.77,0:06:56.64,Main,Chizuru,0,0,0,,Yine mi lan?
Dialogue: 0,0:07:10.12,0:07:12.68,Main,Chizuru,0,0,0,,Piç kurusu! Ne cüretle...
Dialogue: 0,0:07:18.91,0:07:21.73,Italics,Fushiguro,0,0,0,,N'apıyorum ben?
Dialogue: 0,0:07:22.50,0:07:25.26,Italics,Fushiguro,0,0,0,,İleriki zamanlarda da puana ihtiyacım olacak.
Dialogue: 0,0:07:25.26,0:07:29.03,Italics,Fushiguro,0,0,0,,Ama Tsumiki artık kimseyi öldürmek zorunda değil.
Dialogue: 0,0:07:29.49,0:07:30.63,Italics,Fushiguro,0,0,0,,Sakinleş.
Dialogue: 0,0:07:30.63,0:07:32.38,Italics,Fushiguro,0,0,0,,Diğerlerine güven.
Dialogue: 0,0:07:32.38,0:07:34.63,Italics,Fushiguro,0,0,0,,Bunların puanlarına takılma...
Dialogue: 0,0:07:35.30,0:07:37.01,Italics,Fushiguro,0,0,0,,Varım yoğumla...
Dialogue: 0,0:07:37.53,0:07:40.00,Italics,Fushiguro,0,0,0,,başımın çaresine baksam yeter.
Dialogue: 0,0:07:40.56,0:07:43.13,Main,Kogane,0,0,0,,Hanenize beş puan eklendi.
Dialogue: 0,0:07:43.64,0:07:46.95,Main,Reggie,0,0,0,,Ah be, puanlar boşa gitti.
Dialogue: 0,0:07:46.95,0:07:50.72,Main,Reggie,0,0,0,,Tekniğini dahi kullanamadan ölmek ne be...
Dialogue: 0,0:07:52.64,0:07:54.53,Italics,Fushiguro,0,0,0,,Remi gitti mi?
Dialogue: 0,0:07:54.53,0:07:56.72,Italics,Fushiguro,0,0,0,,Gitse bile ikiye bir şu anda.
Dialogue: 0,0:07:56.72,0:07:59.86,Italics,Fushiguro,0,0,0,,Sikeyim, patlamanın etkisi var hâlâ.
Dialogue: 0,0:07:59.86,0:08:01.26,Italics,Fushiguro,0,0,0,,Kaçamam da!
Dialogue: 0,0:08:03.20,0:08:06.00,Italics,Fushiguro,0,0,0,,Kullansam mı... bölgemi...
Dialogue: 0,0:08:06.49,0:08:09.06,Italics,Fushiguro,0,0,0,,Ama bölgem tam bir bölge değil
Dialogue: 0,0:08:09.06,0:08:12.10,Italics,Fushiguro,0,0,0,,bariyerle çevreleyip\N düşmanı içeriye hapsedemem.
Dialogue: 0,0:08:13.21,0:08:17.44,Italics,Fushiguro,0,0,0,,En kötü ihtimal de kaçıp kurtulduktan sonra\N geri savaşa gelmeleri olur.
Dialogue: 0,0:08:21.19,0:08:23.69,Main,Takaba,0,0,0,,DİKKAT ET!
Dialogue: 0,0:08:23.69,0:08:25.54,Main,Takaba,0,0,0,,...ET!
Dialogue: 0,0:08:25.54,0:08:26.90,Main,Takaba,0,0,0,,...ET!
Dialogue: 0,0:08:26.90,0:08:28.78,Main,Takaba,0,0,0,,...ET!
Dialogue: 0,0:08:32.57,0:08:34.26,Main,Takaba,0,0,0,,İkiye bir.
Dialogue: 0,0:08:35.38,0:08:38.57,Main,Takaba,0,0,0,,Sizler gerçekten bunun\N adil olduğunu mu...
Dialogue: 0,0:08:39.21,0:08:40.91,Main,Takaba,0,0,0,,düşünüyorsunuz?
Dialogue: 0,0:08:42.10,0:08:45.27,Main,Takaba,0,0,0,,Var ya sizin gibilere ne derler bilir misiniz?
Dialogue: 0,0:08:46.29,0:08:49.12,Main,Takaba,0,0,0,,Aynen öyle! Korkak bebeler!
Dialogue: 0,0:08:49.12,0:08:51.99,Main,Takaba,0,0,0,,Ve de korkak bebelerin saldırıları bana İŞLEMEZ!
Dialogue: 0,0:08:52.31,0:08:53.57,Main,Takaba,0,0,0,,SEYREDİN!
Dialogue: 0,0:08:55.34,0:08:58.95,Main,Takaba,0,0,0,,SIFIR HASAR ULAN!
Dialogue: 0,0:09:40.18,0:09:42.97,Show_Title,Takaba,0,0,0,,{\fad(1700,0)\3c&HBEDFD4&}JUJUTSU KAISEN
Dialogue: 0,0:09:43.90,0:09:45.98,Show_Title,Takaba,0,0,0,,{\fad(1700,0)\3c&H66A8B0&\shad3\be3}JUJUTSU KAISEN
Dialogue: 0,0:09:45.98,0:09:49.36,Sign_Basic,Screen,0,0,0,,{\pos(960,930)\fnTimes New Roman\b1\bord0\shad0\fs54\1a&H44&}Takaba Fumihiko, Mevcut Puanı: 0
Dialogue: 0,0:09:46.98,0:09:49.36,Main - Top,Takaba,0,0,0,,Genç! Yardım edeceğim sana.
Dialogue: 0,0:09:49.36,0:09:51.25,Main,Takaba,0,0,0,,Bu sene 35'e girdim
Dialogue: 0,0:09:51.25,0:09:54.98,Main,Takaba,0,0,0,,kimin kötü olduğunu şıp diye anları—
Dialogue: 0,0:09:57.54,0:09:58.46,Main,Fushiguro,0,0,0,,Ne var?
Dialogue: 0,0:09:58.85,0:10:02.22,Main,Takaba,0,0,0,,Maşallah senin de tam kötü adam suratın var!
Dialogue: 0,0:10:03.48,0:10:04.77,Main,Takaba,0,0,0,,Bi' şey olmaz!
Dialogue: 0,0:10:04.77,0:10:07.50,Main,Takaba,0,0,0,,Nispeten değerlendiriyorum! Okullardaki gibi!
Dialogue: 0,0:10:07.50,0:10:09.25,Main,Fushiguro,0,0,0,,Okullarda mutlak not sistemi kullanılır.
Dialogue: 0,0:10:09.85,0:10:11.57,Italics,Fushiguro,0,0,0,,Bana siper oldu.
Dialogue: 0,0:10:11.57,0:10:14.03,Italics,Fushiguro,0,0,0,,Şimdilik ona güvenebilirim herhalde...
Dialogue: 0,0:10:14.88,0:10:17.39,Main,Reggie,0,0,0,,Sen ne diyorsun, Hazenoki?
Dialogue: 0,0:10:17.39,0:10:18.69,Main,Hazenoki,0,0,0,,Tanımam etmem.
Dialogue: 0,0:10:18.69,0:10:20.49,Main,Hazenoki,0,0,0,,Sorsam daha hızlı çözeriz.
Dialogue: 0,0:10:20.49,0:10:21.56,Main,Hazenoki,0,0,0,,Hişt!
Dialogue: 0,0:10:21.88,0:10:23.95,Main,Hazenoki,0,0,0,,Sen hangisisin?
Dialogue: 0,0:10:29.19,0:10:30.90,Main,Takaba,0,0,0,,Anladım!
Dialogue: 0,0:10:30.90,0:10:32.95,Main,Takaba,0,0,0,,Yani bana soruyorsun ki...
Dialogue: 0,0:10:33.47,0:10:35.03,Main,Takaba,0,0,0,,komik miyim...
Dialogue: 0,0:10:35.42,0:10:36.91,Main,Takaba,0,0,0,,yoksa değil miyim...
Dialogue: 0,0:10:37.09,0:10:38.73,Main,Takaba,0,0,0,,di' mi?
Dialogue: 0,0:10:39.58,0:10:42.29,Main,Hazenoki,0,0,0,,Yok. Hangi zaman dilimindensin—
Dialogue: 0,0:10:42.29,0:10:44.24,Main,Takaba,0,0,0,,ÜSTÜMDEKİ BU KOSTÜM
Dialogue: 0,0:10:44.24,0:10:46.43,Main,Takaba,0,0,0,,bana İLK DEFA
Dialogue: 0,0:10:46.43,0:10:49.90,Main,Takaba,0,0,0,,kahkahayı öğreten o\N KAHRAMANDAN İLHAM ALINARAK YAPILDI!
Dialogue: 0,0:10:49.90,0:10:51.78,Main,Takaba,0,0,0,,Yani bu kostümün şerefine
Dialogue: 0,0:10:51.78,0:10:54.04,Main,Takaba,0,0,0,,ŞAKALARIMIN PATLAMASINA İZİN VEREMEM!
Dialogue: 0,0:10:54.42,0:11:00.38,Main,Takaba,0,0,0,,İşte az önce aklıma gelen bir espri.\N Sevgiline yaparsın artık.
Dialogue: 0,0:10:58.18,0:11:00.89,Sign_Basic,Screen,0,0,0,,{\c&H171417&\3c&HFFFFFF&\b1\pos(960,630)}Lanet
Dialogue: 0,0:11:03.24,0:11:04.51,Main,Reggie,0,0,0,,Bir şey yapacak!
Dialogue: 0,0:11:04.52,0:11:06.65,Sign_Basic,Screen,0,0,0,,{\fad(0,425)\fs36\b1\c&H0C0B0C&\3c&HFFFFFF&\pos(930,888)}Lanet
Dialogue: 0,0:11:12.09,0:11:14.89,Main,Takaba,0,0,0,,SENİ ALAKADAR N'ETMEZ!
Dialogue: 0,0:11:23.92,0:11:26.79,Main,Takaba,0,0,0,,BOKTAN SEYİRCİLER SİZİ!
Dialogue: 0,0:11:26.79,0:11:28.52,Main,Takaba,0,0,0,,HEP VAR ULAN!
Dialogue: 0,0:11:28.52,0:11:31.67,Main,Takaba,0,0,0,,Sizin gibi anasının karnında gülmeyi unutup
Dialogue: 0,0:11:31.67,0:11:34.70,Main,Takaba,0,0,0,,yine de her sahnede EN ÖNDE OTURANLAR!
Dialogue: 0,0:11:34.70,0:11:36.54,Main,Fushiguro,0,0,0,,Sıkıntı sende sanki.
Dialogue: 0,0:11:36.54,0:11:38.00,Main,Takaba,0,0,0,,AMA BEN VAR YA!
Dialogue: 0,0:11:38.00,0:11:39.44,Italics - Top,Fushiguro,0,0,0,,Aynılar resmen.
Dialogue: 0,0:11:39.44,0:11:41.12,Main,Takaba,0,0,0,,Sizleri görmezden gelmeyeceğim!
Dialogue: 0,0:11:42.09,0:11:44.03,Main,Takaba,0,0,0,,ÇÜNKÜ BEN...
Dialogue: 0,0:11:46.17,0:11:47.89,Main,Takaba,0,0,0,,Komedyenim ya!
Dialogue: 0,0:11:54.44,0:11:55.61,Italics,Reggie,0,0,0,,Hızlı!
Dialogue: 0,0:11:55.61,0:11:57.32,Italics,Reggie,0,0,0,,Lanetli enerjisi birden fırladı!
Dialogue: 0,0:11:57.32,0:11:59.56,Italics,Reggie,0,0,0,,Çıktısındaki değişim devasa!
Dialogue: 0,0:11:59.56,0:12:01.49,Italics,Reggie,0,0,0,,Herif güçlü!
Dialogue: 0,0:12:01.49,0:12:02.83,Main,Takaba,0,0,0,,Dikkat edesin.
Dialogue: 0,0:12:03.04,0:12:08.05,MainTop,Takaba,0,0,0,,Ben şiddetten yana olan\N eski usul komedyenlerdenim.
Dialogue: 0,0:12:08.82,0:12:10.83,Main,Takaba,0,0,0,,Eee, n'apıyoruz...
Dialogue: 0,0:12:10.83,0:12:11.71,Main,Takaba,0,0,0,,GENÇ!
Dialogue: 0,0:12:16.58,0:12:19.01,Main,Fushiguro,0,0,0,,İkisini ayıracağız.
Dialogue: 0,0:12:19.01,0:12:22.90,Main,Fushiguro,0,0,0,,Diğer sahir vücut parçalarını\N bomba gibi patlatabiliyor muhtemelen.
Dialogue: 0,0:12:23.28,0:12:25.56,Main,Fushiguro,0,0,0,,Dahası ters lanetli teknik kullanıy—
Dialogue: 0,0:12:26.11,0:12:27.27,Main,Fushiguro,0,0,0,,DİBİMDESİN!
Dialogue: 0,0:12:27.60,0:12:28.49,Main,Fushiguro,0,0,0,,Kogane!
Dialogue: 0,0:12:28.92,0:12:29.80,Main,Kogane,0,0,0,,Evet?
Dialogue: 0,0:12:30.23,0:12:32.35,Main,Fushiguro,0,0,0,,Higuruma Hiromi'nin bilgilerini göster.
Dialogue: 0,0:12:32.90,0:12:35.15,Player_Info,Screen,0,0,0,,{\an5\c&H508E69&\frx0\fry182\frz356\pos(956.001,132)\fs72}Arama Sonuçları
Dialogue: 0,0:12:32.90,0:12:35.15,Player_Info,Screen,0,0,0,,{\pos(1294.002,333.999)\an5\c&H508E69&\frx0\fry182\frz355}Higuruma Hiromi
Dialogue: 0,0:12:32.90,0:12:35.15,Player_Info,Screen,0,0,0,,{\fs42\fry180\an5\pos(1002,351.999)\c&H37967E&\frz355}Puan
Dialogue: 0,0:12:32.90,0:12:35.15,Player_Info,Screen,0,0,0,,{\fs30\fry180\an5\c&H37967E&\frz355\pos(735.999,393.999)}Eklenen Kural
Dialogue: 0,0:12:32.90,0:12:35.15,Player_Info,Screen,0,0,0,,{\fs42\fry180\an5\frz355\pos(794.001,594)\c&H1A5C41&}Mevcut Koloni: 1. Tokyo
Dialogue: 0,0:12:32.89,0:12:35.15,Italics,Fushiguro,0,0,0,,Kuralı ekleyen İtadori yani.
Dialogue: 0,0:12:35.15,0:12:36.90,Player_Info,Screen,0,0,0,,{\fs90\fry180\an5\c&H7BBAC3&\3c&HA5FFFB&\frz359.2\pos(933.999,517.998)}Puan
Dialogue: 0,0:12:37.25,0:12:39.88,Main,Fushiguro,0,0,0,,Bu Koloni'de işim bitti.
Dialogue: 0,0:12:40.96,0:12:42.66,Main,Fushiguro,0,0,0,,Tüyeceksen salarım seni.
Dialogue: 0,0:12:43.91,0:12:47.29,Main,Reggie,0,0,0,,Ne? Bunu diyecek pozisyonda mısın?
Dialogue: 0,0:12:47.29,0:12:51.28,Main,Reggie,0,0,0,,Hari'yi öldürdüğün için giden puanları\N geri almam lazım!
Dialogue: 0,0:12:51.28,0:12:52.41,Main,Fushiguro,0,0,0,,Sen...
Dialogue: 0,0:12:52.41,0:12:53.65,Main,Takaba,0,0,0,,Takaba ben!
Dialogue: 0,0:12:54.95,0:12:57.76,Main,Fushiguro,0,0,0,,Şu bombacı piçi öldüreceksen
Dialogue: 0,0:12:57.76,0:12:59.32,Main,Fushiguro,0,0,0,,elinden gelirse
Dialogue: 0,0:12:59.32,0:13:01.71,Main,Fushiguro,0,0,0,,önce puanlarını çalmaya odaklan.
Dialogue: 0,0:13:03.23,0:13:04.71,Main,Takaba,0,0,0,,Tamamdır genç.
Dialogue: 0,0:13:05.10,0:13:08.30,Main,Takaba,0,0,0,,Rican başım gözüm üstüne.
Dialogue: 0,0:13:12.73,0:13:14.60,Main,Takaba,0,0,0,,Ama ben komedyenim.
Dialogue: 0,0:13:15.44,0:13:18.60,Main,Takaba,0,0,0,,Bir başkasının suratından gülümsemesini\N eksiltecek iş yapmam asla.
Dialogue: 0,0:13:18.60,0:13:20.90,Main,Fushiguro,0,0,0,,Kazansan yeter bana.
Dialogue: 0,0:13:28.87,0:13:30.79,Sign_Basic,Screen,0,0,0,,{\pos(948,594)\fs36\b1\c&H0C0B0C&\3c&HFFFFFF&}Lanet
Dialogue: 0,0:13:29.37,0:13:30.79,Main,Takaba,0,0,0,,KIVILCIM!
Dialogue: 0,0:13:36.31,0:13:38.09,Main,Takaba,0,0,0,,Ne tehlikeli bir teknik öyle!
Dialogue: 0,0:13:38.41,0:13:39.21,Main,Takaba,0,0,0,,GÜM!
Dialogue: 0,0:13:39.38,0:13:40.44,Main,Takaba,0,0,0,,HAVAİ FİŞEK!
Dialogue: 0,0:13:41.08,0:13:42.47,Main,Takaba,0,0,0,,AMA VAR YA
Dialogue: 0,0:13:42.47,0:13:44.67,Main,Takaba,0,0,0,,EĞLENCE PROGRAMLARINDA...
Dialogue: 0,0:13:49.53,0:13:50.58,Main,Hazenoki,0,0,0,,Yok oldu!
Dialogue: 0,0:13:52.66,0:13:54.57,Main,Takaba,0,0,0,,Kırmızı yasaktır.
Dialogue: 0,0:13:59.86,0:14:00.97,Main,Hazenoki,0,0,0,,Taşak geçme ula—
Dialogue: 0,0:14:07.38,0:14:09.72,Main,Fushiguro,0,0,0,,İyi ki düşman değiliz diyorum, Takaba.
Dialogue: 0,0:14:10.29,0:14:13.45,Main,Takaba,0,0,0,,Hayatta hep duymak istediğim bir REPLİİİİİKTİ!
Dialogue: 0,0:14:14.73,0:14:16.21,Main,Takaba,0,0,0,,Hadi bay, genç!
Dialogue: 0,0:14:16.21,0:14:17.42,Main,Takaba,0,0,0,,Öleyim deme.
Dialogue: 0,0:14:18.74,0:14:20.19,Main,Reggie,0,0,0,,Ah ah.
Dialogue: 0,0:14:20.19,0:14:22.24,Main,Reggie,0,0,0,,Ölüp gidecek eleman.
Dialogue: 0,0:14:22.24,0:14:25.93,Main,Reggie,0,0,0,,O kadar dalgadan sonra\N Hazenoki ciddileşecektir.
Dialogue: 0,0:14:25.93,0:14:28.02,Main,Fushiguro,0,0,0,,Sen kendine bak.
Dialogue: 0,0:14:28.02,0:14:29.19,Main,Fushiguro,0,0,0,,Dedim di' mi?
Dialogue: 0,0:14:29.19,0:14:32.18,Main,Fushiguro,0,0,0,,Bu Koloni'deki işim çoktan bitti.
Dialogue: 0,0:14:32.54,0:14:35.94,Main,Fushiguro,0,0,0,,Varımla yoğumla savaşırım yani.\N Tutmam kendimi.
Dialogue: 0,0:15:16.56,0:15:17.56,Main,Fushiguro,0,0,0,,Maksimum Fil!
Dialogue: 0,0:15:23.97,0:15:26.57,Main,Reggie,0,0,0,,Böylesi de mi var sende!
Dialogue: 0,0:16:51.53,0:16:54.99,Main,Reggie,0,0,0,,Tekniğimi çözdün değil mi?
Dialogue: 0,0:16:54.99,0:16:58.21,Main,Reggie,0,0,0,,Ama sence de suyla saldırman\N fazla basite kaçmıyor mu?
Dialogue: 0,0:17:03.59,0:17:06.17,Main,Fushiguro,0,0,0,,Fişte yazan şeyleri ortaya çıkarıyorsun
Dialogue: 0,0:17:06.17,0:17:08.32,Main,Fushiguro,0,0,0,,ama tam olarak da öyle değil.
Dialogue: 0,0:17:08.84,0:17:10.29,Main,Reggie,0,0,0,,Aynen öyle.
Dialogue: 0,0:17:10.29,0:17:15.11,Main,Reggie,0,0,0,,Tanımlaması zor ama ben buna\N "sözleşmeleri canlandırmak" derim.
Dialogue: 0,0:17:15.11,0:17:17.97,Main,Reggie,0,0,0,,Mesela şöyle de yapabilirim.
Dialogue: 0,0:17:17.97,0:17:20.87,Main,Reggie,0,0,0,,Sözleşmeli Yeniden İnşa.
Dialogue: 0,0:17:24.98,0:17:26.73,Main,Reggie,0,0,0,,Demin kullandığım şey
Dialogue: 0,0:17:26.73,0:17:32.07,Main,Reggie,0,0,0,,beş yıldızlı ryokan Hoshizoratei'de\N iki gece üç günlük konaklama
Dialogue: 0,0:17:32.07,0:17:34.36,Main,Reggie,0,0,0,,ve yağ masajı fişiydi.
Dialogue: 0,0:17:34.36,0:17:44.16,Main,Reggie,0,0,0,,Yani şu anda vücudum tıpkı kaplıcada\N iki gün dinlenip gevşemişim gibi zinde.
Dialogue: 0,0:17:44.16,0:17:46.88,Main,Reggie,0,0,0,,Peki bana kıyasla sen ne hâldesin?
Dialogue: 0,0:17:46.88,0:17:49.06,Main,Reggie,0,0,0,,Deminki dövüşümüzden yaralar aldın
Dialogue: 0,0:17:49.06,0:17:51.46,Main,Reggie,0,0,0,,tek seferde birden çok shikigami kullandın.
Dialogue: 0,0:17:51.46,0:17:53.51,Main,Reggie,0,0,0,,Yorgunluktan geberiyorsundur.
Dialogue: 0,0:17:53.94,0:17:56.32,Italics,Fushiguro,0,0,0,,Sık sık birden çok shikigami kullanırım.
Dialogue: 0,0:17:56.32,0:17:58.09,Italics,Fushiguro,0,0,0,,Asıl sorun
Dialogue: 0,0:17:58.09,0:18:01.44,Italics,Fushiguro,0,0,0,,bu seferkilerden biri, normalde\N tek başına kullandığım Maksimum Fil'di.
Dialogue: 0,0:18:02.70,0:18:06.58,Main,Reggie,0,0,0,,Shikigamilerini şipşak çıkarıp geri çekebiliyorsun
Dialogue: 0,0:18:06.58,0:18:10.45,Main,Reggie,0,0,0,,lakin yaralandıkları vakit öyle olmuyor, di' mi?
Dialogue: 0,0:18:10.45,0:18:14.08,Main,Reggie,0,0,0,,Aynı anda koşup, saldırıp, savunma yapabilen\N kurdunu çağıramıyorsun o yüzden.
Dialogue: 0,0:18:14.08,0:18:15.20,Main,Reggie,0,0,0,,Dolayısıyla
Dialogue: 0,0:18:15.20,0:18:19.24,Main,Reggie,0,0,0,,tek numaran olan, bir seferde birden çok\N shikigami taktiğine muhtaç kaldın.
Dialogue: 0,0:18:19.24,0:18:23.79,Main,Reggie,0,0,0,,Bu, ikimizin de büyük ve yüksek güçlü hamleler\N yapamadığı bir yıpratma savaşı.
Dialogue: 0,0:18:23.79,0:18:25.35,Main,Reggie,0,0,0,,Nafile işte.
Dialogue: 0,0:18:25.35,0:18:27.70,Main,Reggie,0,0,0,,Beni öldüremezsin.
Dialogue: 0,0:18:29.79,0:18:31.09,Main,Fushiguro,0,0,0,,Aynen öyle.
Dialogue: 0,0:18:31.09,0:18:32.51,Main,Fushiguro,0,0,0,,O hâlde kaçarım.
Dialogue: 0,0:18:32.72,0:18:33.90,Main,Reggie,0,0,0,,Hop.
Dialogue: 0,0:18:42.74,0:18:44.57,Main,Reggie,0,0,0,,O kadar kolay olmayacak.
Dialogue: 0,0:18:49.36,0:18:49.90,Sign_Basic,Screen,0,0,0,,{\fnArial\b1\fs48\pos(878.001,261.999)\shad0\c&H352D2B&\3c&H8F7D89&}Mobil Dron
Dialogue: 0,0:18:49.94,0:18:51.36,Sign_Basic,Screen,0,0,0,,{\fad(175,0)\fnArial\b1\fs30\shad0\c&HFFDFE6&\bord0\pos(956.001,397.998)\frz6.413}Pazartesi, 12 Kasım
Dialogue: 0,0:18:56.29,0:18:58.76,Main,Reggie,0,0,0,,Belediye salonu mu?
Dialogue: 0,0:18:58.76,0:19:01.88,Main,Reggie,0,0,0,,İçeri mi kaçtı? \N Yoksa beni mi yemliyor?
Dialogue: 0,0:19:01.88,0:19:03.90,Main,Reggie,0,0,0,,Ateş kullansam ortaya çıkarırım da
Dialogue: 0,0:19:03.90,0:19:07.38,Main,Reggie,0,0,0,,ama bi' tur daha ebelemece\N oynamaya tahammülüm yok.
Dialogue: 0,0:19:07.38,0:19:09.79,Main,Reggie,0,0,0,,Ee, n'apsam ki ya?
Dialogue: 0,0:19:11.28,0:19:13.67,Italics,Fushiguro,0,0,0,,Güzel. Tam düşündüğüm gibi.
Dialogue: 0,0:19:14.18,0:19:16.08,Italics,Fushiguro,0,0,0,,Boyutlar kusursuz.
Dialogue: 0,0:19:17.18,0:19:21.51,Main,Reggie,0,0,0,,N'apmayı planlıyorsun ha, geri zekâlı efendi?
Dialogue: 0,0:19:22.57,0:19:25.62,Main,Fushiguro,0,0,0,,Asıl bi' şeyler planlayan sensin, di' mi?
Dialogue: 0,0:19:30.62,0:19:33.64,Main,Reggie,0,0,0,,Sahirlerde yalan mübahtır di' mi?
Dialogue: 0,0:20:29.71,0:20:33.41,Main,Reggie,0,0,0,,Yarattığım şeyler shikigami misali
Dialogue: 0,0:20:33.41,0:20:36.63,Main,Reggie,0,0,0,,onlara basit emirler verebiliyorum yani.
Dialogue: 0,0:20:36.63,0:20:39.45,Main,Reggie,0,0,0,,Bıçaklar normalde uçamaz di' mi?
Dialogue: 0,0:20:40.46,0:20:44.52,Main,Reggie,0,0,0,,Kişiliğine aldanarak, söylemenin anlamsız\N olduğunu düşünsem de söyleyeceğim.
Dialogue: 0,0:20:44.52,0:20:47.80,Main,Reggie,0,0,0,,Eğer puanlarını bana verirsen\N öbür tarafa huzurlu yollarım seni.
Dialogue: 0,0:20:48.90,0:20:52.26,Main,Fushiguro,0,0,0,,Bariyer teknikleri harbi meşakkatli...
Dialogue: 0,0:20:53.32,0:20:55.25,Main,Fushiguro,0,0,0,,Ne kadar denediysem deneyeyim
Dialogue: 0,0:20:55.25,0:21:00.53,Main,Fushiguro,0,0,0,,uzay zamanın üzerine başka boyutta yapay bir uzay yaratmanın esasını kavrayamadım gitti.
Dialogue: 0,0:20:58.24,0:21:00.53,Main,Fushiguro,0,0,0,,
Dialogue: 0,0:21:00.53,0:21:01.75,Main,Fushiguro,0,0,0,,Bu yüzden...
Dialogue: 0,0:21:02.70,0:21:03.99,Italics,Reggie,0,0,0,,Hadi oradan...
Dialogue: 0,0:21:05.31,0:21:08.82,Main,Fushiguro,0,0,0,,Bu salonun içerisindeki boşluğu
Dialogue: 0,0:21:08.82,0:21:11.71,Main,Fushiguro,0,0,0,,bölgemi konuşlandırmak için kullanacağım.
Dialogue: 0,0:21:11.71,0:21:13.38,Italics,Reggie,0,0,0,,Kullanabiliyor mu?
Dialogue: 0,0:21:33.59,0:21:35.38,Main,Fushiguro,0,0,0,,Bölgesel Genişleme:
Dialogue: 0,0:21:35.89,0:21:37.35,Main,Fushiguro,0,0,0,,Kimera Gölge Bahçesi.
Dialogue: 0,0:21:41.82,0:21:44.57,Sign_Basic,Screen,0,0,0,,{\pos(960,930)\fnTimes New Roman\b1\bord0\shad0\fs54\1a&H44&}Bölgesel Genişleme: Kimera Gölge Bahçesi.
Dialogue: 0,0:21:44.57,0:21:47.95,Italics,Reggie,0,0,0,,Bu kadar kabiliyetli bi' sahir mi yani?
Dialogue: 0,0:21:48.47,0:21:52.45,Main,Fushiguro,0,0,0,,Sana hiç... kozum yok falan demedim.
Dialogue: 0,0:23:26.11,0:23:29.55,Main,Fushiguro,0,0,0,,Tamamlanmamış da olsa bölge bölgedir!
Dialogue: 0,0:23:28.89,0:23:31.54,Main - Top,Reggie,0,0,0,,Kozumu ortaya çıkartıyorum o hâlde!
Dialogue: 0,0:23:31.54,0:23:33.11,Main,Fushiguro,0,0,0,,Daha değil! Az daha dayanmalıyım!
Dialogue: 0,0:23:33.11,0:23:34.03,Main,Reggie,0,0,0,,Gücünü kabul ediyorum.
Dialogue: 0,0:23:34.03,0:23:35.94,Main,Fushiguro,0,0,0,,İLK HANGİMİZ EZİLECEK!
Dialogue: 0,0:23:35.94,0:23:38.43,Main,Reggie,0,0,0,,EZİL ULAN!
